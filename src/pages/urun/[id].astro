      }

      .thumb-btn.active {
        border-color: var(--brand-gold);
        transform: scale(1.05);
        box-shadow: 0 4px 12px rgba(212, 175, 55, 0.15);
      }

      /* SAĞ SÜTUN: DETAY KARTI */
      .detail-info-card {
        display: flex;
        flex-direction: column;
        justify-content: center;
      }

      .detail-badge {
        display: inline-flex;
        align-self: flex-start;
        background: rgba(85, 107, 47, 0.08);
        border: 1px solid rgba(85, 107, 47, 0.25);
        color: var(--brand-olive);
        font-weight: 700;
        font-size: 0.8rem;
        letter-spacing: 1.5px;
        padding: 0.45rem 1rem;
        border-radius: 50px;
        margin-bottom: 1.2rem;
        text-transform: uppercase;
      }

      .detail-title {
        font-size: 2.5rem;
        font-weight: 800;
        color: var(--text-dark);
        line-height: 1.2;
        margin-bottom: 0.8rem;
      }

      .rating-stars {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 1.8rem;
      }

      .stars-gold {
        color: #f1c40f;
        font-size: 1.1rem;
      }

      .rating-text {
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--brand-olive);
      }

      /* Fiyat Kutusu */
      .detail-price-card {
        background: linear-gradient(135deg, rgba(212, 175, 55, 0.05) 0%, rgba(250, 248, 245, 0.9) 100%);
        border: 1px solid rgba(212, 175, 55, 0.2);
        border-radius: 20px;
        padding: 1.5rem 1.8rem;
        margin-bottom: 2rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        position: relative;
        overflow: hidden;
      }

      .detail-price-card::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: linear-gradient(45deg, transparent 45%, rgba(212, 175, 55, 0.05) 50%, transparent 55%);
        animation: shine 4s infinite linear;
      }

      .price-row {
        display: flex;
        align-items: baseline;
        gap: 1rem;
      }

      .price-old-styled {
        font-size: 1.2rem;
        color: var(--text-muted);
        text-decoration: line-through;
        font-weight: 500;
      }

      .price-sale-styled {
        font-size: 2.8rem;
        font-weight: 800;
        color: var(--brand-gold-dark);
        line-height: 1;
      }

      .price-badge-discount {
        display: inline-block;
        background: #c0392b;
        color: white;
        font-size: 0.8rem;
        font-weight: 700;
        padding: 0.25rem 0.6rem;
        border-radius: 6px;
        align-self: flex-start;
      }

      /* Özellikler */
      .detail-features-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--text-dark);
        margin-bottom: 0.8rem;
        letter-spacing: 0.5px;
      }

      .detail-features-list {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 0.8rem;
        margin-bottom: 2.2rem;
      }

      .detail-features-list li {
        display: flex;
        align-items: flex-start;
        gap: 0.8rem;
        color: var(--text-muted);
        font-size: 1rem;
      }

      .detail-features-list li .bullet {
        color: var(--brand-gold);
        font-weight: bold;
        flex-shrink: 0;
        font-size: 1.1rem;
        line-height: 1;
        margin-top: 1px;
      }

      /* Butonlar */
      .detail-actions-group {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1rem;
      }

      @media (min-width: 480px) {
        .detail-actions-group {
          grid-template-columns: 1fr 1fr;
        }
      }

      .btn-detail-add-cart, .btn-detail-instant-checkout {
        position: relative;
        overflow: hidden;
        z-index: 1;
        padding: 1.1rem 2rem;
        border-radius: 14px;
        font-size: 1.05rem;
        font-weight: 700;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.8rem;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        border: none;
        background: linear-gradient(135deg, var(--brand-gold) 0%, var(--brand-gold-dark) 100%);
        color: white;
        box-shadow: 0 10px 25px rgba(212, 175, 55, 0.2);
      }

      /* Premium Light-Sweep Shimmer Effect */
      .btn-detail-add-cart::before, .btn-detail-instant-checkout::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 50%;
        height: 100%;
        background: linear-gradient(
          to right,
          rgba(255, 255, 255, 0) 0%,
          rgba(255, 255, 255, 0.3) 50%,
          rgba(255, 255, 255, 0) 100%
        );
        transform: skewX(-25deg);
        transition: 0.75s;
        z-index: -1;
      }

      .btn-detail-add-cart:hover::before, .btn-detail-instant-checkout:hover::before {
        left: 150%;
        transition: 0.75s;
      }

      .btn-detail-add-cart:hover, .btn-detail-instant-checkout:hover {
        transform: translateY(-3px);
        box-shadow: 0 15px 30px rgba(212, 175, 55, 0.35);
      }

      .btn-detail-add-cart:active, .btn-detail-instant-checkout:active {
        transform: translateY(-1px);
      }

      /* SVG Arrow & Icon Translate on Hover */
      .btn-detail-add-cart svg, .btn-detail-instant-checkout svg {
        transition: transform 0.3s ease;
      }

      .btn-detail-add-cart:hover svg, .btn-detail-instant-checkout:hover svg {
        transform: translateX(4px);
      }

      /* DERİNLERE INİŞ & MULTIMEDYA */
      .deep-dive-section {
        background: rgba(255, 255, 255, 0.45);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(212, 175, 55, 0.15);
        border-radius: 32px;
        padding: 3rem 2.5rem;
        margin-bottom: 4rem;
        box-shadow: 0 15px 50px rgba(44, 37, 32, 0.03);
      }

      .deep-dive-header {
        text-align: center;
        max-width: 700px;
        margin: 0 auto 3rem;
      }

      .deep-dive-badge {
        display: inline-block;
        background: var(--brand-olive);
        color: white;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 2px;
        padding: 0.4rem 1rem;
        border-radius: 30px;
        margin-bottom: 1rem;
        text-transform: uppercase;
      }

      .deep-dive-title {
        font-size: 2.2rem;
        font-weight: 800;
        color: var(--text-dark);
        margin-bottom: 1rem;
      }

      .deep-dive-subtitle {
        font-size: 1.15rem;
        color: var(--brand-olive);
        font-weight: 500;
      }

      .deep-dive-intro-p {
        font-size: 1.1rem;
        line-height: 1.7;
        color: var(--text-muted);
        text-align: center;
        max-width: 900px;
        margin: 0 auto 3rem;
      }

      /* Özellik Detayları Grid */
      .features-detail-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 2rem;
        margin-bottom: 3.5rem;
      }

      .feature-detail-card {
        background: white;
        border: 1px solid rgba(212, 175, 55, 0.12);
        padding: 1.8rem;
        border-radius: 20px;
        transition: all 0.3s ease;
        box-shadow: 0 6px 20px rgba(44, 37, 32, 0.01);
      }

      .feature-detail-card:hover {
        transform: translateY(-5px);
        border-color: var(--brand-gold);
        box-shadow: 0 10px 25px rgba(212, 175, 55, 0.08);
      }

      .feature-card-icon {
        width: 44px;
        height: 44px;
        background: rgba(212, 175, 55, 0.1);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--brand-gold-dark);
        font-size: 1.25rem;
        margin-bottom: 1.2rem;
        font-weight: bold;
      }

      .feature-card-title {
        font-size: 1.15rem;
        font-weight: 700;
        color: var(--text-dark);
        margin-bottom: 0.6rem;
      }

      .feature-card-text {
        font-size: 0.95rem;
        color: var(--text-muted);
        line-height: 1.6;
      }

      /* Nasıl Kullanılır Bölümü */
      .how-to-use-box {
        background: linear-gradient(135deg, rgba(85, 107, 47, 0.03) 0%, rgba(212, 175, 55, 0.03) 100%);
        border: 1px solid rgba(85, 107, 47, 0.15);
        border-radius: 20px;
        padding: 2rem;
        display: flex;
        gap: 1.5rem;
        align-items: center;
      }

      @media (max-width: 768px) {
        .how-to-use-box {
          flex-direction: column;
          text-align: center;
          gap: 1rem;
        }
      }

      .use-icon {
        font-size: 2.5rem;
        flex-shrink: 0;
      }

      .use-content h4 {
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--brand-olive);
        margin-bottom: 0.4rem;
      }

      .use-content p {
        font-size: 1rem;
        color: var(--text-muted);
        line-height: 1.6;
      }

      /* GÜVEN ROZETLERİ */
      .badges-section {
        margin-bottom: 4rem;
      }

      .badges-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.5rem;
      }

      .badge-card {
        background: white;
        border: 1px solid rgba(212, 175, 55, 0.15);
        padding: 2rem;
        border-radius: 20px;
        display: flex;
        gap: 1.2rem;
        align-items: flex-start;
        box-shadow: 0 10px 25px rgba(44, 37, 32, 0.02);
        transition: all 0.3s ease;
      }

      .badge-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 12px 30px rgba(212, 175, 55, 0.06);
      }

      .badge-icon {
        font-size: 2.2rem;
        flex-shrink: 0;
      }

      .badge-info h3 {
        font-size: 1.15rem;
        font-weight: 700;
        color: var(--text-dark);
        margin-bottom: 0.4rem;
      }

      .badge-info p {
        font-size: 0.95rem;
        color: var(--text-muted);
        line-height: 1.5;
      }

      /* VİDEO GALERİSİ */
      .videos-section {
        background: rgba(255, 255, 255, 0.35);
        border: 1px solid rgba(212, 175, 55, 0.15);
        border-radius: 32px;
        padding: 3rem 2.5rem;
        margin-bottom: 4rem;
      }

      .videos-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 2rem;
        margin-top: 2rem;
      }

      @media (min-width: 968px) {
        .videos-grid {
          grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
        }
      }

      .video-wrapper-card {
        background: white;
        border: 1px solid rgba(212, 175, 55, 0.15);
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 8px 25px rgba(44, 37, 32, 0.02);
      }

      .iframe-container {
        position: relative;
        width: 100%;
        padding-top: 56.25%; /* 16:9 Aspect Ratio */
      }

      .iframe-container iframe {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        border: 0;
      }

      /* SIKÇA SORULAN SORULAR */
      .faq-section {
        margin-bottom: 4rem;
      }

      .faq-accordion {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        max-width: 850px;
        margin: 2rem auto 0;
      }

      .faq-item {
        background: white;
        border: 1px solid rgba(212, 175, 55, 0.15);
        border-radius: 16px;
        overflow: hidden;
        transition: all 0.3s ease;
      }

      .faq-item:hover {
        border-color: var(--brand-gold);
        box-shadow: 0 4px 15px rgba(212, 175, 55, 0.05);
      }

      .faq-item details {
        padding: 1.25rem 1.5rem;
      }

      .faq-item summary {
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--text-dark);
        cursor: pointer;
        display: flex;
        justify-content: space-between;
        align-items: center;
        user-select: none;
        outline: none;
      }

      .faq-item summary::-webkit-details-marker {
        display: none;
      }

      .faq-item summary::after {
        content: '＋';
        font-size: 1.2rem;
        color: var(--brand-gold-dark);
        font-weight: bold;
        transition: transform 0.3s ease;
      }

      .faq-item details[open] summary::after {
        content: '−';
        transform: rotate(180deg);
      }

      .faq-content {
        padding-top: 1rem;
        color: var(--text-muted);
        font-size: 0.98rem;
        line-height: 1.6;
        border-top: 1px dashed rgba(212, 175, 55, 0.12);
        margin-top: 1rem;
      }

      /* Ortak Tipografi & Yardımcı Sınıflar */
      .section-title {
        font-size: 2.2rem;
        font-weight: 800;
        text-align: center;
        color: var(--text-dark);
        margin-bottom: 0.5rem;
      }

      .section-title span {
        color: var(--brand-gold-dark);
      }

      .section-subtitle {
        text-align: center;
        color: var(--text-muted);
        max-width: 600px;
        margin: 0 auto 3rem;
        font-size: 1.05rem;
      }

      /* FOOTER */
      footer {
        border-top: 1px solid rgba(212, 175, 55, 0.15);
        background: rgba(44, 37, 32, 0.02);
        padding: 3.5rem 1.5rem 2.5rem;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
        margin-top: 2rem;
        position: relative;
        z-index: 1;
      }

      .social-link {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        color: var(--brand-olive);
        font-weight: 700;
        font-size: 1.05rem;
        text-decoration: none;
        padding: 0.8rem 1.8rem;
        border-radius: 50px;
        background: white;
        border: 1px solid rgba(85, 107, 47, 0.2);
        box-shadow: 0 4px 15px rgba(85, 107, 47, 0.05);
        transition: all 0.3s ease;
      }

      .social-link:hover {
        background: var(--brand-olive);
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(85, 107, 47, 0.15);
      }

      .copyright {
        font-size: 0.95rem;
        color: var(--text-muted);
        font-weight: 500;
        line-height: 1.6;
      }

      /* ANIMATIONS */
      @keyframes rotate {
        100% { transform: rotate(360deg); }
      }

      @keyframes shine {
        0% { left: -100%; }
        100% { left: 100%; }
      }

      @keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-10px); }
      }

      @keyframes bounce {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.25); }
      }

      @keyframes slideDown {
        from { opacity: 0; transform: translateY(-15px); }
        to { opacity: 1; transform: translateY(0); }
      }

      @keyframes fadeInDown {
        from { opacity: 0; transform: translateY(-30px); }
        to { opacity: 1; transform: translateY(0); }
      }

      @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(35px); }
        to { opacity: 1; transform: translateY(0); }
      }

      /* Premium Adet Seçici (Product Detail Page) */
      .detail-action-wrapper {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .detail-quantity-selector {
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: rgba(255, 255, 255, 0.7);
        border: 1px solid rgba(212, 175, 55, 0.3);
        border-radius: 16px;
        padding: 0.5rem 1rem;
        height: 58px;
        box-sizing: border-box;
        box-shadow: 0 10px 25px rgba(212, 175, 55, 0.08);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        width: 100%;
        animation: fadeIn 0.3s ease;
      }

      .detail-quantity-selector:hover {
        box-shadow: 0 15px 35px rgba(212, 175, 55, 0.18);
        border-color: var(--brand-gold-dark, #c5a028);
      }

      .detail-quantity-selector .btn-qty-action {
        background: rgba(212, 175, 55, 0.08);
        border: 1px solid rgba(212, 175, 55, 0.25);
        color: var(--brand-gold-dark);
        width: 42px;
        height: 42px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        box-shadow: 0 4px 10px rgba(212, 175, 55, 0.05);
        padding: 0;
      }

      .detail-quantity-selector .btn-qty-action:hover {
        background: linear-gradient(135deg, var(--brand-gold) 0%, var(--brand-gold-dark) 100%);
        border-color: transparent;
        color: white;
        transform: scale(1.12);
        box-shadow: 0 6px 15px rgba(212, 175, 55, 0.3);
      }

      .detail-quantity-selector .btn-qty-action:active {
        transform: scale(0.9);
      }

      .detail-quantity-selector .btn-qty-action svg {
        stroke: currentColor;
        display: block;
      }

      .detail-quantity-selector .qty-display {
        display: inline-flex;
        align-items: baseline;
        justify-content: center;
        gap: 3px;
        font-family: 'Outfit', sans-serif;
        color: var(--brand-olive-dark, #3b4e18);
        user-select: none;
      }

      .detail-quantity-selector .qty-num {
        font-size: 1.35rem;
        font-weight: 800;
      }

      .detail-quantity-selector .qty-unit {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--brand-gold-dark, #c5a028);
        text-transform: uppercase;
        letter-spacing: 0.5px;
      }

      @keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
      }

      @keyframes buttonPulse {
        0% {
          box-shadow: 0 10px 25px rgba(212, 175, 55, 0.2);
        }
        50% {
          box-shadow: 0 10px 30px rgba(212, 175, 55, 0.4), 0 0 0 4px rgba(212, 175, 55, 0.15);
        }
        100% {
          box-shadow: 0 10px 25px rgba(212, 175, 55, 0.2);
        }
      }
    </style>
  </head>
  <body>
    
    <!-- PREMIUM STICKY HEADER -->
    <nav class="premium-nav-header">
      <div class="nav-container">
        <!-- Sol: Geri Dön -->
        <a href="/" class="btn-back-to-store">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
          </svg>
          <span>Mağazaya Dön</span>
        </a>

        <!-- Orta: Marka Logosu & İsim -->
        <a href="/" class="nav-logo-area">
          <div class="nav-logo-ring">
            <img src="/images/logo.jpg" alt="ES Yaşam Logo" class="nav-logo-img" />
          </div>
          <span class="nav-brand-name">ES YAŞAM</span>
        </a>

        <!-- Sağ: Boş Flex Dengesi -->
        <div class="nav-right-actions"></div>
      </div>
    </nav>

    <div class="container">
      
      <!-- HERO GRID SECTION -->
      <section class="hero-grid">
        
        <!-- Sol: Görsel slideshow -->
        <div class="detail-media-card" data-local-images={JSON.stringify(localImagesList)} data-build-images={JSON.stringify(imagesList)}>
          <div class="slideshow-wrapper">
            {imagesList.map((img, index) => (
              <img 
                src={img} 
                alt={`${product.name} Görsel ${index + 1}`} 
                class={`slide-img ${index === 0 ? "active" : ""}`} 
                data-index={index}
                loading={index === 0 ? "eager" : "lazy"}
              />
            ))}
            
            {imagesList.length > 1 && (
              <>
                <button class="slide-btn slide-prev" id="prev-slide-btn">❮</button>
                <button class="slide-btn slide-next" id="next-slide-btn">❯</button>
                <div class="slide-dots">
                  {imagesList.map((_, index) => (
                    <span class={`dot ${index === 0 ? "active" : ""}`} data-index={index}></span>
                  ))}
                </div>
              </>
            )}
          </div>

          {imagesList.length > 1 && (
            <div class="slides-thumbnails">
              {imagesList.map((img, index) => (
                <button class={`thumb-btn ${index === 0 ? "active" : ""}`} data-index={index}>
                  <img src={img} alt="Küçük Görsel" />
                </button>
              ))}
            </div>
          )}
        </div>

        <!-- Sağ: Ürün Detayları -->
        <div class="detail-info-card">
          <div class="detail-badge">✦ {deepDive.badge} VİRAL ÜRÜN ✦</div>
          <h1 class="detail-title">{product.name}</h1>
          
          <div class="rating-stars">
            <div class="stars-gold">★★★★★</div>
            <div class="rating-text">5.0 (1,480+ Değerlendirme) - Memnuniyet Odaklı Hizmet</div>
          </div>

          <!-- Fiyat Bölümü -->
          <div class="detail-price-card">
            <span class="price-badge-discount">%20'ye Varan Tasarruf</span>
            <div class="price-row">
              {originalPrice && <span class="price-old-styled">{originalPrice} TL</span>}
              <span class="price-sale-styled">{currentPrice} TL</span>
            </div>
            <p style="font-size: 0.85rem; color: var(--text-muted); font-weight: 600; display: flex; align-items: center; gap: 0.3rem; margin-top: 0.2rem;">
              <span style="color: var(--brand-olive);">●</span> Stoklarımız güncel tutulmaktadır.
            </p>
          </div>

          <!-- Özellikler Listesi -->
          <div class="detail-features-title">✨ Özel Formülünün Öne Çıkan Faydaları</div>
          <ul class="detail-features-list">
            {(product.features || product.detay || "").split('\n').filter(Boolean).map((feature) => (
              <li>
                <span class="bullet">✦</span>
                <span>{feature.replace(/^[✓\s*-]+/, '')}</span>
