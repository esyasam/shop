    <!-- INTERACTIVE SCRIPT -->
    <script is:inline>
      // ==========================================
      // DETAIL PAGE SLIDESHOW RUNTIME LOGIC
      // ==========================================
      let currentSlideIndex = 0;

      function showSlide(index) {
        const slides = document.querySelectorAll('.slide-img');
        const dots = document.querySelectorAll('.dot');
        const thumbs = document.querySelectorAll('.thumb-btn');
        if (slides.length === 0) return;

        if (index >= slides.length) { currentSlideIndex = 0; }
        else if (index < 0) { currentSlideIndex = slides.length - 1; }
        else { currentSlideIndex = index; }

        window.currentSlideIndex = currentSlideIndex;

        slides.forEach(slide => slide.classList.remove('active'));
        if (dots.length > 0) dots.forEach(dot => dot.classList.remove('active'));
        if (thumbs.length > 0) thumbs.forEach(thumb => thumb.classList.remove('active'));

        slides[currentSlideIndex].classList.add('active');
        if (dots[currentSlideIndex]) dots[currentSlideIndex].classList.add('active');
        if (thumbs[currentSlideIndex]) thumbs[currentSlideIndex].classList.add('active');
      }

      // Modül scriptlerimizin de slideshow'u kontrol edebilmesi için pencere kapsamına ekle
      window.showSlide = showSlide;
      window.currentSlideIndex = currentSlideIndex;

      // ==========================================
      // PRODUCT DETAIL ACTION GENERATORS
      // ==========================================
      function getDetailQtySelectorHtml(id, name, price, image, qty) {
        return `
          <div class="detail-quantity-selector" data-id="${id}" data-name="${name}" data-price="${price}" data-image="${image}">
            <button class="btn-qty-action btn-qty-minus" data-id="${id}" aria-label="Azalt">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"></line>
              </svg>
            </button>
            <div class="qty-display">
              <span class="qty-num">${qty}</span>
              <span class="qty-unit">Adet</span>
            </div>
            <button class="btn-qty-action btn-qty-plus" data-id="${id}" aria-label="Artır">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
              </svg>
            </button>
          </div>
        `;
      }

      function getDetailAddButtonHtml(id, name, price, image) {
        return `
          <button class="btn-detail-add-cart" id="add-to-cart-btn" data-id="${id}" data-name="${name}" data-price="${price}" data-image="${image}">
            <span>Sepete Ekle</span>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="9" cy="21" r="1"></circle>
              <circle cx="20" cy="21" r="1"></circle>
              <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
            </svg>
          </button>
        `;
      }

      function updateDetailPageButton(cartList) {
        if (!cartList) return;
        const wrapper = document.querySelector('.detail-action-wrapper');
        if (!wrapper) return;

        const id = wrapper.getAttribute('data-id');
        const name = wrapper.getAttribute('data-name');
        const price = wrapper.getAttribute('data-price');
        const image = wrapper.getAttribute('data-image');
        
        const cartItem = cartList.find(item => String(item.id) === String(id));
        if (cartItem) {
          wrapper.innerHTML = getDetailQtySelectorHtml(id, name, price, image, cartItem.quantity);
        } else {
          wrapper.innerHTML = getDetailAddButtonHtml(id, name, price, image);
        }
      }

      // Listen to custom cart updates (Globally, to avoid DOMContentLoaded race conditions)
      window.addEventListener('cart-updated', (e) => {
        updateDetailPageButton(e.detail.cart);
      });

      // ==========================================
      // INITIAL BINDINGS ON LOAD
      // ==========================================
      window.addEventListener('DOMContentLoaded', () => {
        // Render button based on loaded cart state
        if (window.cart) {
          updateDetailPageButton(window.cart);
        }

        // Slideshow controls
        const prevBtn = document.getElementById('prev-slide-btn');
        const nextBtn = document.getElementById('next-slide-btn');
        const dots = document.querySelectorAll('.dot');
        const thumbs = document.querySelectorAll('.thumb-btn');

        if (prevBtn) prevBtn.addEventListener('click', () => showSlide(currentSlideIndex - 1));
        if (nextBtn) nextBtn.addEventListener('click', () => showSlide(currentSlideIndex + 1));

        dots.forEach(dot => {
          dot.addEventListener('click', () => {
            const idx = parseInt(dot.getAttribute('data-index'));
            showSlide(idx);
          });
        });

        thumbs.forEach(thumb => {
          thumb.addEventListener('click', () => {
            const idx = parseInt(thumb.getAttribute('data-index'));
            showSlide(idx);
          });
        });

        // Connect Navbar Cart Button
        const navCartBtn = document.getElementById('nav-cart-btn');
        if (navCartBtn) {
          navCartBtn.addEventListener('click', () => {
            if (window.openCartDrawer) window.openCartDrawer();
          });
        }

        // Click Actions via Event Delegation
        document.addEventListener('click', (e) => {
          // Add to cart click
          const addBtn = e.target.closest('.btn-detail-add-cart');
          if (addBtn) {
            e.preventDefault();
            e.stopPropagation();
            const wrapper = addBtn.closest('.detail-action-wrapper');
            if (wrapper) {
              const id = wrapper.getAttribute('data-id');
              const name = wrapper.getAttribute('data-name');
              const price = wrapper.getAttribute('data-price');
              const image = wrapper.getAttribute('data-image');
              if (window.addToCart) {
                window.addToCart(id, name, price, image);
              }
            }
            return;
          }

          // Minus click
          const minusBtn = e.target.closest('.btn-qty-minus');
          if (minusBtn) {
            e.preventDefault();
            e.stopPropagation();
            const id = minusBtn.getAttribute('data-id');
            if (window.updateItemQty) {
              window.updateItemQty(id, -1);
            }
            return;
          }

          // Plus click
          const plusBtn = e.target.closest('.btn-qty-plus');
          if (plusBtn) {
            e.preventDefault();
            e.stopPropagation();
            const id = plusBtn.getAttribute('data-id');
            if (window.updateItemQty) {
              window.updateItemQty(id, 1);
            }
            return;
          }
        });

        // Instant Checkout Action
        const instantCheckoutBtn = document.getElementById('instant-checkout-btn');
        if (instantCheckoutBtn) {
          instantCheckoutBtn.addEventListener('click', () => {
            const id = instantCheckoutBtn.getAttribute('data-id');
            const name = instantCheckoutBtn.getAttribute('data-name');
            const price = instantCheckoutBtn.getAttribute('data-price');
            const image = instantCheckoutBtn.getAttribute('data-image');
            
            if (window.addToCart && window.openCheckoutDrawer) {
              // Add to cart with quantity 1, then open drawer and go directly to checkout form
              window.addToCart(id, name, price, image, 1);
              window.openCheckoutDrawer();
            }
          });
        }

        // ==========================================
        // SOCIAL SHARING SYSTEM LOGIC
        // ==========================================
        const shareModal = document.getElementById('share-modal');
        const shareModalClose = document.getElementById('share-modal-close');
        const shareLinkInput = document.getElementById('share-link-input');
        const shareCopyBtn = document.getElementById('share-copy-btn');
        const shareToast = document.getElementById('share-toast');

        // Set share link input value to current URL
        if (shareLinkInput) {
          shareLinkInput.value = window.location.href;
        }

        function openShareModal() {
          if (shareModal) {
            shareModal.classList.add('active');
            document.body.classList.add('modal-open');
          }
        }

        function closeShareModal() {
          if (shareModal) {
            shareModal.classList.remove('active');
            document.body.classList.remove('modal-open');
          }
        }

        function triggerShare() {
          openShareModal();
        }

        // Connect share buttons (nav-share-btn and floating-share-btn)
        const navShareBtn = document.getElementById('nav-share-btn');
        const floatingShareBtn = document.getElementById('floating-share-btn');

        if (navShareBtn) navShareBtn.addEventListener('click', triggerShare);
        if (floatingShareBtn) floatingShareBtn.addEventListener('click', triggerShare);

        // Close button click
        if (shareModalClose) {
          shareModalClose.addEventListener('click', closeShareModal);
        }

        // Close on clicking backdrop
        if (shareModal) {
          shareModal.addEventListener('click', (e) => {
            if (e.target === shareModal) {
              closeShareModal();
            }
          });
        }

        // Copy link event
        if (shareCopyBtn && shareLinkInput) {
          shareCopyBtn.addEventListener('click', () => {
            shareLinkInput.select();
            shareLinkInput.setSelectionRange(0, 99999); // For mobile devices
            navigator.clipboard.writeText(shareLinkInput.value)
              .then(() => {
                // Show toast
                if (shareToast) {
                  shareToast.classList.add('show');
                  setTimeout(() => {
                    shareToast.classList.remove('show');
                  }, 2500);
                }
              })
              .catch(err => {
                console.error('Failed to copy text: ', err);
              });
          });
        }

        // Social channels click handlers
        const channelBtns = document.querySelectorAll('.share-channel-btn');
        channelBtns.forEach(btn => {
          btn.addEventListener('click', () => {
            const channel = btn.getAttribute('data-channel');
            const pageUrl = encodeURIComponent(window.location.href);
            const pageText = encodeURIComponent(document.title + " - ES Yaşam lüks temizlik formülünü keşfedin! ✨");
            let shareUrl = '';

            if (channel === 'whatsapp') {
              shareUrl = `https://api.whatsapp.com/send?text=${pageText}%20${pageUrl}`;
            } else if (channel === 'telegram') {
              shareUrl = `https://t.me/share/url?url=${pageUrl}&text=${pageText}`;
            } else if (channel === 'twitter') {
              shareUrl = `https://twitter.com/intent/tweet?url=${pageUrl}&text=${pageText}`;
            }

            if (shareUrl) {
              window.open(shareUrl, '_blank', 'noopener,noreferrer');
            }
          });
        });
      });
    </script>

    <!-- REAL-TIME FIREBASE HYBRID SYNC SCRIPT (YÖNTEM 1) -->
    <script is:inline type="module">
      import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
      import { getDatabase, ref, onValue } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-database.js";

      // ES Yaşam Firebase Realtime Database Yapılandırması
      const firebaseConfig = {
        databaseURL: "https://esyasam77-default-rtdb.europe-west1.firebasedatabase.app",
        projectId: "esyasam77"
      };

      const app = initializeApp(firebaseConfig);
      const db = getDatabase(app);

      // Slayt kontrollerini dinamik olarak yeniden bağla (Rebind Events)
      function rebindSlideshowControls() {
        const prevBtn = document.getElementById('prev-slide-btn');
        const nextBtn = document.getElementById('next-slide-btn');
        
        if (prevBtn) {
          prevBtn.addEventListener('click', () => {
            if (window.showSlide && window.currentSlideIndex !== undefined) {
              window.showSlide(window.currentSlideIndex - 1);
            }
          });
        }
        if (nextBtn) {
          nextBtn.addEventListener('click', () => {
            if (window.showSlide && window.currentSlideIndex !== undefined) {
              window.showSlide(window.currentSlideIndex + 1);
            }
          });
        }

        const dots = document.querySelectorAll('.dot');
        dots.forEach(dot => {
          dot.addEventListener('click', () => {
            const idx = parseInt(dot.getAttribute('data-index'));
            if (window.showSlide) window.showSlide(idx);
          });
        });

        const thumbs = document.querySelectorAll('.thumb-btn');
        thumbs.forEach(thumb => {
          thumb.addEventListener('click', () => {
            const idx = parseInt(thumb.getAttribute('data-index'));
            if (window.showSlide) window.showSlide(idx);
          });
        });
      }

      // Detay sayfası slayt gösterisini dinamik olarak yeniden oluştur (DOM Injection)
      function updateDetailPageSlideshow(imagesList, productName) {
        const mediaCard = document.querySelector('.detail-media-card');
        if (!mediaCard) return;

        let slideshowHtml = `
          <div class="slideshow-wrapper">
            ${imagesList.map((img, index) => `
              <img 
                src="${img}" 
                alt="${productName} Görsel ${index + 1}" 
                class="slide-img ${index === 0 ? 'active' : ''}" 
                data-index="${index}"
                loading="${index === 0 ? 'eager' : 'lazy'}"
                onerror="this.onerror=null; this.src='/images/stok_logo.webp';"
              />
            `).join('')}
            
            ${imagesList.length > 1 ? `
              <button class="slide-btn slide-prev" id="prev-slide-btn">❮</button>
              <button class="slide-btn slide-next" id="next-slide-btn">❯</button>
              <div class="slide-dots">
                ${imagesList.map((_, index) => `
                  <span class="dot ${index === 0 ? 'active' : ''}" data-index="${index}"></span>
                `).join('')}
              </div>
            ` : ''}
          </div>

          ${imagesList.length > 1 ? `
            <div class="slides-thumbnails">
              ${imagesList.map((img, index) => `
                <button class="thumb-btn ${index === 0 ? 'active' : ''}" data-index="${index}">
                  <img src="${img}" alt="Küçük Görsel" onerror="this.onerror=null; this.src='/images/stok_logo.webp';" />
                </button>
              `).join('')}
            </div>
          ` : ''}
        `;

        if (mediaCard.innerHTML !== slideshowHtml) {
          mediaCard.innerHTML = slideshowHtml;
          rebindSlideshowControls();
          if (window.showSlide) window.showSlide(0); // Slaytı ilk elemandan başlat
        }
      }

      // Tarayıcı adres çubuğundan ürün ID'sini tespit et (Son derece güvenli ve standart yöntem)
      const pathParts = window.location.pathname.split('/');
      let productId = pathParts[pathParts.length - 1] || pathParts[pathParts.length - 2];
      if (productId) {
        productId = productId.replace('.html', '').replace('.htm', '');
      }

      if (productId) {
        // Firebase RTDB üzerindeki bu spesifik ürünü dinle
        onValue(ref(db, `products/${productId}`), (snapshot) => {
          const product = snapshot.val();
          if (!product) return;

          // Fiyat ve indirim durumlarını hesapla (Astro sunucu tarafı mantığı ile birebir uyumlu)
          const campaignPriceNum = parseFloat(product.campaignPrice);
          const salePriceNum = parseFloat(product.salePrice) || 0;
          const hasCampaign = !isNaN(campaignPriceNum) && campaignPriceNum > 0 && campaignPriceNum < salePriceNum;
          const currentPrice = hasCampaign ? campaignPriceNum : salePriceNum;
          const originalPrice = hasCampaign ? salePriceNum : null;

          // Yerel görselleri data-local-images özelliğinden al
          const mediaCard = document.querySelector('.detail-media-card');
          const localImagesAttr = mediaCard ? mediaCard.getAttribute('data-local-images') : null;
          const localImages = localImagesAttr ? JSON.parse(localImagesAttr) : [`/images/${product.id || productId}.webp`];

          // Firebase'deki görsel alanını çöz ve yerel listeye ekle
          const imageField = product.image || product.gorsel;
          const externalImages = [];
          if (imageField && imageField.trim() !== "") {
            let rawImages = imageField.includes(',') ? imageField.split(',').map(img => img.trim()) : [imageField.trim()];
            rawImages.forEach(img => {
              let resolved = img;
              if (!img.includes('/')) {
                resolved = `/images/${img}`;
              }
              if (!localImages.includes(resolved) && !externalImages.includes(resolved)) {
                externalImages.push(resolved);
              }
            });
          }

          const imagesList = [...localImages, ...externalImages];
          const resolvedImg = imagesList[0] || `/images/stok_logo.webp`;

          // 1. Ürün Adını Güncelle
          const titleEl = document.querySelector('.detail-title');
          if (titleEl && titleEl.textContent !== product.name) {
            titleEl.textContent = product.name;
          }

          // 2. Çoklu Görselleri/Slayt Gösterisini Canlı Güncelle
          updateDetailPageSlideshow(imagesList, product.name);

          // 3. Özellikler Listesini Güncelle
          const featuresList = document.querySelector('.detail-features-list');
          const productFeatures = product.features || product.detay;
          if (featuresList && productFeatures) {
            const features = productFeatures.split('\n').filter(Boolean);
            const featuresHtml = features.map(feature => `
              <li>
                <span class="bullet">✦</span>
                <span>${feature.replace(/^[✓\s*-]+/, '')}</span>
              </li>
            `).join('');

            if (featuresList.innerHTML !== featuresHtml) {
              featuresList.innerHTML = featuresHtml;
            }
          }

          // 4. Fiyat Bölümünü Güncelle
          const priceRow = document.querySelector('.price-row');
          if (priceRow) {
            let newPriceHtml = '';
            if (originalPrice) {
              newPriceHtml += `<span class="price-old-styled">${originalPrice} TL</span> `;
            }
            newPriceHtml += `<span class="price-sale-styled">${currentPrice} TL</span>`;

            if (priceRow.innerHTML !== newPriceHtml) {
              priceRow.innerHTML = newPriceHtml;
            }
          }

          // 5. Detay Sayfası Buton ve Sarmalayıcı Özniteliklerini Güncelle (Sepet işlemleri için hayati!)
          const detailWrapper = document.querySelector('.detail-action-wrapper');
          if (detailWrapper) {
            detailWrapper.setAttribute('data-name', product.name);
            detailWrapper.setAttribute('data-price', currentPrice);
            detailWrapper.setAttribute('data-image', resolvedImg);

            const addCartBtn = detailWrapper.querySelector('#add-to-cart-btn');
            if (addCartBtn) {
              addCartBtn.setAttribute('data-name', product.name);
              addCartBtn.setAttribute('data-price', currentPrice);
              addCartBtn.setAttribute('data-image', resolvedImg);
            }

            const qtySelector = detailWrapper.querySelector('.detail-quantity-selector');
            if (qtySelector) {
              qtySelector.setAttribute('data-name', product.name);
              qtySelector.setAttribute('data-price', currentPrice);
              qtySelector.setAttribute('data-image', resolvedImg);
            }
          }

          const checkoutBtn = document.getElementById('instant-checkout-btn');
          if (checkoutBtn) {
            checkoutBtn.setAttribute('data-name', product.name);
            checkoutBtn.setAttribute('data-price', currentPrice);
            checkoutBtn.setAttribute('data-image', resolvedImg);
          }

          // 6. Sepette Ekle/Adet Buton Durumunu Senkronize Et
          if (window.cart && typeof updateDetailPageButton === 'function') {
            updateDetailPageButton(window.cart);
          }

          // 7. Detaylı Bilgi Bölümlerini (Deep Dive) Güncelle
          try {
            const badge = product.detailBadge || product.detail_badge || product.detay_badge || product.detayBadge;
            const title = product.detailTitle || product.detail_title || product.detay_baslik || product.detayBaslik;
            const subtitle = product.detailSubtitle || product.detail_subtitle || product.detay_alt_baslik || product.detayAltBaslik;
            const intro = product.detailIntro || product.detail_intro || product.detay_giris || product.detayGiris || product.desc_deep || product.deep_dive_intro;
            const usage = product.detailUsage || product.detail_usage || product.detay_kullanim || product.detayKullanim || product.usage || product.kullanim;

            // Features parse etme
            const features = [];
            for (let i = 1; i <= 4; i++) {
              const fTitle = product[`feature${i}Title`] || product[`feature${i}_title`] || product[`detay_ozellik${i}_baslik`] || product[`detayOzellik${i}Baslik`];
              const fText = product[`feature${i}Text`] || product[`feature${i}_text`] || product[`detay_ozellik${i}_metin`] || product[`detayOzellik${i}Metin`];
              if (fTitle || fText) {
                features.push({
                  title: fTitle || "",
                  text: fText || ""
                });
              }
            }

            const finalBadge = badge || "PREMIUM";
            const finalTitle = title || "";
            const finalSubtitle = subtitle || "";
            const finalIntro = intro || "";
            const finalUsage = usage || "";
            const finalFeatures = features;

            // Deep dive bölümü görünürlük kontrolü
            const ddSection = document.querySelector('.deep-dive-section');
            if (ddSection) {
              const hasContent = finalTitle || finalSubtitle || finalIntro || finalUsage || finalFeatures.length > 0;
              ddSection.style.display = hasContent ? '' : 'none';
            }

            // UI Güncelleme: Deep Dive Badge
            const ddBadgeEl = document.querySelector('.deep-dive-badge');
            if (ddBadgeEl) {
              const badgeText = finalBadge || "Formül Sırrı";
              if (ddBadgeEl.textContent !== badgeText) {
                ddBadgeEl.textContent = badgeText;
              }
            }

            // UI Güncelleme: Detail Badge (Sağ detay kartındaki)
            const detailBadgeEl = document.querySelector('.detail-badge');
            if (detailBadgeEl) {
              const badgeText = `✦ ${finalBadge} VİRAL ÜRÜN ✦`;
              if (detailBadgeEl.textContent !== badgeText) {
                detailBadgeEl.textContent = badgeText;
              }
            }

            // UI Güncelleme: Deep Dive Title
            const ddTitleEl = document.querySelector('.deep-dive-title');
            if (ddTitleEl && ddTitleEl.textContent !== finalTitle) {
              ddTitleEl.textContent = finalTitle;
            }

            // UI Güncelleme: Deep Dive Subtitle
            const ddSubtitleEl = document.querySelector('.deep-dive-subtitle');
            if (ddSubtitleEl && ddSubtitleEl.textContent !== finalSubtitle) {
              ddSubtitleEl.textContent = finalSubtitle;
            }

            // UI Güncelleme: Deep Dive Intro
            const ddIntroEl = document.querySelector('.deep-dive-intro-p');
            if (ddIntroEl && ddIntroEl.textContent !== finalIntro) {
              ddIntroEl.textContent = finalIntro;
            }

            // UI Güncelleme: Usage
            const ddUsageEl = document.querySelector('.how-to-use-box .use-content p');
            if (ddUsageEl && ddUsageEl.textContent !== finalUsage) {
              ddUsageEl.textContent = finalUsage;
            }

            // UI Güncelleme: Features Grid
            const ddFeaturesGrid = document.querySelector('.features-detail-grid');
            if (ddFeaturesGrid) {
              const featuresHtml = finalFeatures.map((feat, index) => `
                <div class="feature-detail-card">
                  <div class="feature-card-icon">0${index + 1}</div>
                  <h3 class="feature-card-title">${feat.title}</h3>
                  <p class="feature-card-text">${feat.text}</p>
                </div>
              `).join('');

              if (ddFeaturesGrid.innerHTML !== featuresHtml) {
                ddFeaturesGrid.innerHTML = featuresHtml;
              }
            }
          } catch (err) {
            console.error("Deep dive sync error:", err);
          }
        });
      }
    </script>
  </body>
</html>

