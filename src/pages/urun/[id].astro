<!DOCTYPE html>
<html lang="tr">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO Meta Etiketleri -->
    <title>{product.name} - ES Yaşam | Premium Ürün Özellikleri</title>
    <meta name="description" content={`${product.name} için hazırlanan ultra-premium detay sayfası. Ürün özelliklerini, tanıtım videolarını ve kullanım detaylarını inceleyin, Instagram @es_yasam üzerinden kolayca sipariş verin.`} />
    <meta name="robots" content="index, follow" />
    
    <!-- Open Graph (Sosyal Medya Paylaşım ve Önizleme Kartları) -->
    <meta property="og:title" content={`${product.name} - ES Yaşam`} />
    <meta property="og:description" content={`${product.name} lüks temizlik formülüyle tanışın. Özellikleri inceleyin ve Instagram DM üzerinden kolayca sipariş verin!`} />
    <meta property="og:image" content={mainImage} />
    <meta property="og:url" content={`https://esyasam.com/urun/${product.id}`} />
    <meta property="og:type" content="product" />
    <meta property="og:price:amount" content={currentPrice} />
    <meta property="og:price:currency" content="TRY" />
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style>
      :root {
        --brand-gold: #d4af37;
        --brand-gold-dark: #c5a028;
        --brand-olive: #556b2f;
        --brand-olive-light: #8fbc8f;
        --bg-cream: #FAF8F5;
        --bg-cream-dark: #F5F2EB;
        --text-muted: #6e645e;
      }

      /* Premium Custom Scrollbars */
      ::-webkit-scrollbar {
        width: 8px;
        height: 8px;
      }
      ::-webkit-scrollbar-track {
        background: var(--bg-cream-dark);
      }
      ::-webkit-scrollbar-thumb {
        background: rgba(212, 175, 55, 0.3);
        border-radius: 10px;
        border: 2px solid var(--bg-cream-dark);
        transition: background 0.3s ease;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: var(--brand-gold);
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family: 'Outfit', sans-serif;
        background: radial-gradient(circle at top, var(--bg-cream) 0%, var(--bg-cream-dark) 100%);
        color: var(--text-dark);
        min-height: 100vh;
        overflow-x: hidden;
        position: relative;
        line-height: 1.5;
        padding-bottom: 4rem;
      }

      body.modal-open {
        overflow: hidden;
      }

      /* Dekoratif Arka Plan Yaprak Desenleri */
      body::before, body::after {
        content: '';
        position: absolute;
        width: 400px;
        height: 400px;
        opacity: 0.05;
        background-image: radial-gradient(var(--brand-olive) 1.5px, transparent 1px);
        background-size: 32px 32px;
        pointer-events: none;
        z-index: 0;
      }
      body::before { top: 5%; left: -100px; }
      body::after { bottom: 15%; right: -100px; }

      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 1.5rem 1.5rem;
        position: relative;
        z-index: 1;
      }

      /* LÜKS STICKY HEADER */
