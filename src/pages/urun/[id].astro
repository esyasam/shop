      intro: "ES Yaşam Sarı Güç, mutfağınızdan banyonuza kadar evinizin her köşesinde mucizeler yaratan çok amaçlı lüks bir temizleyicidir. Doğal narenciye özlerinin gücüyle zenginleştirilmiş formülü, kurumuş yağları, birikmiş kirleri ve kireç lekelerini ovalamaya gerek kalmadan zahmetsizce söker atar.",
      features: [
        { title: "Ultra Yağ Çözücü Formül", text: "Ocak, fırın, aspiratör ve mutfak tezgahlarındaki en ağır, yanmış yağ tabakalarını anında sıvılaştırır." },
        { title: "Doğal Narenciye Gücü", text: "Gerçek portakal ve limon kabuğu yağları içerir. Doğal asitleriyle yüzeyleri aşındırmadan parlatır." },
        { title: "Durulama Gerektirmeyen Kolaylık", text: "Uygulandığı yüzeyde yapışkan kalıntı veya iz bırakmaz, durulama süresini yarı yarıya azaltır." },
        { title: "Evdeki Tüm Yüzeylere Tek Çözüm", text: "Mutfak tezgahlarından PVC pencerelere, bahçe mobilyalarından fayans aralarına kadar çok yönlü kullanım sunar." }
      ],
      usage: "Temizlemek istediğiniz yüzeye püskürtün. Ağır yağ ve kirlerde 30-60 saniye bekleyin, ardından temiz bir bezle silin. Parlak ve lekesiz bir görünüm için kuru bir mikrofiber bezle son dokunuşu yapabilirsiniz.",
      badge: "ÇOK AMAÇLI"
    };
  } else if (lowercaseName.includes("mavi") || lowercaseName.includes("blue")) {
    return {
      title: "Mavi Güç - Ultra Hijyen ve Parlaklık",
      subtitle: "Cam, Metal ve Parlak Yüzeylerde Kusursuz Işıltı ve Uzun Süre Toz Tutmama Etkisi",
