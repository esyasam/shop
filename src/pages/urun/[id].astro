// ES Yaşam - Bağımsız Premium Ürün Detay Sayfası
import fs from 'node:fs';
import path from 'node:path';
import CartDrawer from '../../components/CartDrawer.astro';

const databaseUrl = "https://esyasam77-default-rtdb.europe-west1.firebasedatabase.app";
const url = `${databaseUrl}/products.json`;

export async function getStaticPaths() {
  const databaseUrl = "https://esyasam77-default-rtdb.europe-west1.firebasedatabase.app";
  const url = `${databaseUrl}/products.json`;
  try {
    const response = await fetch(url);
    if (response.ok) {
      const data = await response.json();
      if (data) {
        const products = Object.values(data);
        return products.map((product: any) => ({
          params: { id: String(product.id) },
          props: { product, allProducts: products }
        }));
      }
    }
  } catch (error) {
    console.error(" getStaticPaths hatası:", error);
  }
  return [];
}

const { id } = Astro.params;
const { product, allProducts } = Astro.props;

// Fiyat ayarlamaları
const campaignPriceNum = parseFloat(product.campaignPrice);
const salePriceNum = parseFloat(product.salePrice) || 0;
const hasCampaign = !isNaN(campaignPriceNum) && campaignPriceNum > 0 && campaignPriceNum < salePriceNum;

const currentPrice = hasCampaign ? campaignPriceNum : salePriceNum;
const originalPrice = hasCampaign ? salePriceNum : null;

// Görsel çözme
function resolveProductImage(image, id) {
  // 1. Ürün ID'si ile eşleşen bir görselin direkt public/images altında olup olmadığını kontrol et (ör. 50200.webp)
  try {
    const idPath = path.join(process.cwd(), 'public', 'images', `${id}.webp`);
    if (fs.existsSync(idPath)) {
      return `/images/${id}.webp`;
    }
  } catch (e) {
    // ignore
  }

  // 2. Belirtilen görsel adının direkt public/images altında olup olmadığını kontrol et
  if (image && !image.includes("/")) {
    try {
      const directPath = path.join(process.cwd(), 'public', 'images', image);
      if (fs.existsSync(directPath)) {
        return `/images/${image}`;
      }
    } catch (e) {
      // ignore
    }
  }

  // 3. Resmi bulunmayan ürünler için stok_logo.webp kontrolü ve fallback kullanımı
  try {
    const defaultLogoPath = path.join(process.cwd(), 'public', 'images', 'stok_logo.webp');
    if (fs.existsSync(defaultLogoPath)) {
      return '/images/stok_logo.webp';
    }
  } catch (e) {
    // ignore
  }

  // 4. Klasik/eski eşleme mantığı (fallback)
  if (!image) {
    return `/images/products/${id}/cover.webp`;
  }
  if (!image.includes("/")) {
    return `/images/products/${id}/${image}`;
  }
  return image;
}

const mainImage = resolveProductImage(product.image, product.id);

// Çoklu görseller
function getProductImagesList(imageField, productId) {
  // 1. Ürün ID'si ile eşleşen bir görselin direkt public/images altında olup olmadığını kontrol et
  try {
    const idPath = path.join(process.cwd(), 'public', 'images', `${productId}.webp`);
    if (fs.existsSync(idPath)) {
      return [`/images/${productId}.webp`];
    }
  } catch (e) {
    // ignore
  }

  // 1.5 Resmi bulunmayan ürünler için stok_logo.webp kontrolü ve fallback kullanımı
  try {
    const defaultLogoPath = path.join(process.cwd(), 'public', 'images', 'stok_logo.webp');
    if (fs.existsSync(defaultLogoPath)) {
      return ['/images/stok_logo.webp'];
    }
  } catch (e) {
    // ignore
  }

  // 2. Orijinal bölünmüş/haritalanmış mantık
  if (!imageField) {
    return [`/images/products/${productId}/cover.webp`];
  }
  let images = [];
  if (imageField.includes(',')) {
    images = imageField.split(',').map((img: string) => img.trim());
  } else {
    images = [imageField.trim()];
  }
  return images.map((img: string) => {
    if (!img.includes('/')) {
      try {
        const directPath = path.join(process.cwd(), 'public', 'images', img);
        if (fs.existsSync(directPath)) {
          return `/images/${img}`;
        }
      } catch (e) {
        // ignore
      }
      return `/images/products/${productId}/${img}`;
    }
    return img;
  });
}

const imagesList = getProductImagesList(product.image, product.id);

// Çoklu videolar
function getProductVideosList(videoField) {
  if (!videoField) return [];
  let videos = [];
  if (videoField.includes(',')) {
    videos = videoField.split(',').map((vid: string) => vid.trim()).filter(Boolean);
  } else {
    videos = [videoField.trim()];
  }

  return videos.map((vid: string) => {
    let videoId = "";
    if (vid.includes("youtube.com/shorts/")) {
      videoId = vid.split("youtube.com/shorts/")[1].split("?")[0].split("&")[0];
    } else if (vid.includes("youtu.be/")) {
      videoId = vid.split("youtu.be/")[1].split("?")[0].split("&")[0];
    } else if (vid.includes("v=")) {
      videoId = vid.split("v=")[1].split("&")[0];
    } else if (vid.length === 11) {
      videoId = vid;
    }
    return videoId ? `https://www.youtube.com/embed/${videoId}` : null;
  }).filter(Boolean);
}

const videosList = getProductVideosList(product.video || product.links);

// Pazarlama Açıklamaları ve Derinlemesine Anlatım
function getProductDeepDiveContent(name, id) {
  const lowercaseName = name.toLowerCase();
  
  if (lowercaseName.includes("leke")) {
    return {
      title: "Leke Çıkartıcı - Viral Temizlik Mucizesi",
      subtitle: "Kumaşlarınıza Zarar Vermeden, En Zorlu Lekelere Saniyeler İçinde Veda Edin",
      intro: "ES Yaşam Leke Çıkartıcı, en inatçı lekeleri bile kökünden çözen özel ve lüks formülüyle temizlik standartlarınızı tamamen değiştiriyor. Kıyafetlerinizden koltuklarınıza, halılarınızdan hassas dokulara kadar her yüzeyde güvenle kullanabileceğiniz bu mucizevi formül, derinlemesine hijyen sunarken lifleri korur.",
      features: [
        { title: "Aktif Enzim Teknolojisi", text: "Kahve, çay, yağ, şarap ve çamur gibi en inatçı organik lekeleri saniyeler içinde çözüp kumaştan ayırır." },
        { title: "Renk ve Doku Koruyucu", text: "Özel formülü sayesinde kumaşların canlı renklerini soldurmaz, dokusuna zarar vermez ve yıpratmaz." },
        { title: "Zeytin Çiçeği Premium Esansı", text: "Temizlik sonrasında kimyasal kokular yerine evinize hafif, lüks ve taze bir doğallık kokusu yayar." },
        { title: "Geniş Kullanım Alanı", text: "Kıyafetler, gömlek yakaları, halılar, perdeler, araç koltukları ve tüm döşemelik kumaşlar için mükemmel sonuç sunar." }
      ],
