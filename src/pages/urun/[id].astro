  } else {
    return {
      title: `${name} - ES Yaşam Lüks Serisi`,
      subtitle: "Daha Güzel ve Ferah Bir Yaşam İçin Doğadan İlham Alan Lüks Formül",
      intro: "ES Yaşam ailesinin lüks standartlarıyla üretilen bu özel formül, evinizde hijyen ve ferahlığı bir araya getiriyor. Doğal bileşenlerin gücünü modern temizlik teknolojisiyle birleştiren ürünümüz, hem ailenizin sağlığını korur hem de evinizde kalıcı ve asil bir hijyen sağlar.",
      features: [
        { title: "Organik Bileşenlerle Zengin", text: "İnsan sağlığına zararlı sert kimyasallar barındırmaz, gücünü doğallıktan alır." },
        { title: "Lüks ve Yoğun Etki", text: "Az miktarda kullanımda bile maksimum temizlik gücü sunar, ekonomiktir." },
        { title: "Zarif Koku Kartelası", text: "Kalıcı ve hafif esansları ile evinizin havasını uzun süre taze tutar." },
        { title: "Doğa Dostu Ambalaj", text: "Doğada %100 geri dönüştürülebilir lüks şişe tasarımıyla çevreye duyarlıdır." }
      ],
      usage: "İlgili yüzeye püskürtün veya nemli bez yardımıyla uygulayın. Hafifçe silerek asil parlaklığı ve derin temizliği ortaya çıkarın.",
