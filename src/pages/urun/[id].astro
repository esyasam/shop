// ES Yaşam - Bağımsız Premium Ürün Detay Sayfası
import fs from 'node:fs';
import path from 'node:path';
import CartDrawer from '../../components/CartDrawer.astro';

const databaseUrl = "https://esyasam77-default-rtdb.europe-west1.firebasedatabase.app";
const url = `${databaseUrl}/products.json`;

export async function getStaticPaths() {
  const databaseUrl = "https://esyasam77-default-rtdb.europe-west1.firebasedatabase.app";
  const url = `${databaseUrl}/products.json`;
  try {
    const response = await fetch(url);
    if (response.ok) {
      const data = await response.json();
      if (data) {
        const products = Object.values(data);
        return products.map((product: any) => ({
          params: { id: String(product.id) },
          props: { product, allProducts: products }
        }));
      }
    }
  } catch (error) {
    console.error(" getStaticPaths hatası:", error);
  }
  return [];
}

const { id } = Astro.params;
const { product, allProducts } = Astro.props;

// Fiyat ayarlamaları
const campaignPriceNum = parseFloat(product.campaignPrice);
const salePriceNum = parseFloat(product.salePrice) || 0;
const hasCampaign = !isNaN(campaignPriceNum) && campaignPriceNum > 0 && campaignPriceNum < salePriceNum;

const currentPrice = hasCampaign ? campaignPriceNum : salePriceNum;
const originalPrice = hasCampaign ? salePriceNum : null;

// Çoklu görseller (Detay Sayfası Slayt Gösterisi İçin)
function getProductImagesList(imageField, productId) {
  const localImages = [];
  const publicImagesDir = path.join(process.cwd(), 'public', 'images');
  
  // 1. Ana görsel: [id].webp var mı?
  if (fs.existsSync(path.join(publicImagesDir, `${productId}.webp`))) {
    localImages.push(`/images/${productId}.webp`);
  }
  
  // 2. Çoklu görseller: [id]_[1..10].webp var mı?
  for (let i = 1; i <= 10; i++) {
    const name = `${productId}_${i}.webp`;
    if (fs.existsSync(path.join(publicImagesDir, name))) {
      localImages.push(`/images/${name}`);
    }
  }

  // 3. Alternatif çoklu görseller: [id]-[1..10].webp var mı?
  for (let i = 1; i <= 10; i++) {
    const name = `${productId}-${i}.webp`;
    if (fs.existsSync(path.join(publicImagesDir, name)) && !localImages.includes(`/images/${name}`)) {
      localImages.push(`/images/${name}`);
    }
  }

  // 4. Firebase'den gelen harici görsel tanımları (virgülle ayrılmış liste veya tekil URL)
  const externalImages = [];
  if (imageField && imageField.trim() !== "") {
    let rawImages = [];
    if (imageField.includes(',')) {
      rawImages = imageField.split(',').map((img: string) => img.trim());
    } else {
      rawImages = [imageField.trim()];
    }

    rawImages.forEach((img: string) => {
      let resolved = img;
      if (!img.includes('/')) {
        if (fs.existsSync(path.join(publicImagesDir, img))) {
          resolved = `/images/${img}`;
        } else {
          resolved = `/images/products/${productId}/${img}`;
        }
      }
      if (!localImages.includes(resolved) && !externalImages.includes(resolved)) {
        externalImages.push(resolved);
      }
    });
  }

  const allImages = [...localImages, ...externalImages];
  if (allImages.length === 0) {
    if (fs.existsSync(path.join(publicImagesDir, 'logo.jpg'))) {
      return ['/images/logo.jpg'];
    }
    return ['/images/logo.jpg'];
  }

  return allImages;
}

const localImagesList = getProductImagesList("", product.id);
const imagesList = getProductImagesList(product.image || product.gorsel, product.id);
const mainImage = imagesList[0] || `/images/logo.jpg`;
const absoluteMainImage = mainImage.startsWith('http') ? mainImage : `https://esyasam.com${mainImage}`;

// Çoklu videolar
function getProductVideosList(videoField) {
  if (!videoField) return [];
  let videos = [];
  if (videoField.includes(',')) {
    videos = videoField.split(',').map((vid: string) => vid.trim()).filter(Boolean);
  } else {
    videos = [videoField.trim()];
  }

  return videos.map((vid: string) => {
    let videoId = "";
    if (vid.includes("youtube.com/shorts/")) {
      videoId = vid.split("youtube.com/shorts/")[1].split("?")[0].split("&")[0];
    } else if (vid.includes("youtu.be/")) {
      videoId = vid.split("youtu.be/")[1].split("?")[0].split("&")[0];
    } else if (vid.includes("v=")) {
      videoId = vid.split("v=")[1].split("&")[0];
    } else if (vid.length === 11) {
      videoId = vid;
    }
    return videoId ? `https://www.youtube.com/embed/${videoId}` : null;
  }).filter(Boolean);
}

const videosList = getProductVideosList(product.video || product.links);

// Pazarlama Açıklamaları ve Derinlemesine Anlatım
function getProductDeepDiveContent(product) {
  if (!product) return { badge: "", title: "", subtitle: "", intro: "", usage: "", features: [] };

  // Read dynamic fields if they exist
  const badge = product.detailBadge || product.detail_badge || product.detay_badge || product.detayBadge;
  const title = product.detailTitle || product.detail_title || product.detay_baslik || product.detayBaslik;
  const subtitle = product.detailSubtitle || product.detail_subtitle || product.detay_alt_baslik || product.detayAltBaslik;
  const intro = product.detailIntro || product.detail_intro || product.detay_giris || product.detayGiris || product.desc_deep || product.deep_dive_intro;
  const usage = product.detailUsage || product.detail_usage || product.detay_kullanim || product.detayKullanim || product.usage || product.kullanim;

  // Try to parse features
  const features = [];
  for (let i = 1; i <= 4; i++) {
    const fTitle = product[`feature${i}Title`] || product[`feature${i}_title`] || product[`detay_ozellik${i}_baslik`] || product[`detayOzellik${i}Baslik`];
    const fText = product[`feature${i}Text`] || product[`feature${i}_text`] || product[`detay_ozellik${i}_metin`] || product[`detayOzellik${i}Metin`];
    if (fTitle || fText) {
      features.push({
        title: fTitle || "",
        text: fText || ""
      });
    }
  }

  return {
    badge: badge || "PREMIUM",
    title: title || "",
    subtitle: subtitle || "",
    intro: intro || "",
    usage: usage || "",
    features: features
  };
}

const deepDive = getProductDeepDiveContent(product);
