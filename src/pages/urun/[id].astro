      features: [
        { title: "İzsiz ve Çiziksiz Işıltı", text: "Cam ve aynalarda en ufak bir dalgalanma veya bez izi bırakmadan kristal berraklığında parlaklık sağlar." },
        { title: "Toz Önleyici Koruyucu Bariyer", text: "Yüzeyde statik elektriklenmeyi engelleyen görünmez bir mikro tabaka oluşturarak tozların tutunmasını geciktirir." },
        { title: "Su ve Kireç Lekesi Karşıtı", text: "Duşakabin, fayans ve musluklardaki su damlacıklarının ve kirecin tutunmasını engelleyerek kurumasını önler." },
        { title: "Premium Okyanus Esintisi", text: "Evinize gün boyu süren, ferahlatıcı ve derin lüks bir okyanus tazeliği kokusu kazandırır." }
      ],
      usage: "Yüzeye yaklaşık 20 cm mesafeden hafifçe püskürtün. Temiz ve kuru bir cam bezi veya mikrofiber bez yardımıyla dairesel hareketlerle silin. Durulama gerektirmez.",
      badge: "ULTRA PARLAKLIK"
