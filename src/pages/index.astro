<html lang="tr">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO Meta Etiketleri -->
    <title>ES Yaşam - Daha güzel bir yaşam için | Premium Mağaza</title>
    <meta name="description" content="Leke Çıkartıcı, Sarı Güç ve Mavi Güç lansman ürünlerimiz için hazırlanan ultra-premium, yüksek dönüşümlü e-ticaret satış sayfamız. Tüm ürünlerimizi inceleyin ve Instagram @es_yasam üzerinden kolayca sipariş verin." />
    <meta name="robots" content="index, follow" />
    
    <!-- Open Graph (Sosyal Medya Paylaşım ve Önizleme Kartları) -->
    <meta property="og:title" content="ES Yaşam - Daha güzel bir yaşam için" />
    <meta property="og:description" content="Doğadan ilham alan lüks formüllü temizlik ürünlerimizle tanışın. Stoklarımız her zaman güncel tutulmaktadır. Instagram DM üzerinden kolayca sipariş verin!" />
    <meta property="og:image" content="https://esyasam.com/images/logo.jpg" />
    <meta property="og:url" content="https://esyasam.com" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ES Yaşam" />
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style>
      :root {
        --brand-gold: #d4af37;
        --brand-gold-dark: #c5a028;
        --brand-olive: #556b2f;
        --brand-olive-light: #8fbc8f;
        --bg-cream: #FAF8F5;
        --bg-cream-dark: #F5F2EB;
        --text-dark: #2c2520;
        --text-muted: #6e645e;
      }

      /* Premium Custom Scrollbars */
      ::-webkit-scrollbar {
        width: 8px;
        height: 8px;
      }
      ::-webkit-scrollbar-track {
        background: var(--bg-cream-dark);
      }
      ::-webkit-scrollbar-thumb {
        background: rgba(212, 175, 55, 0.3);
        border-radius: 10px;
        border: 2px solid var(--bg-cream-dark);
        transition: background 0.3s ease;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: var(--brand-gold);
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family: 'Outfit', sans-serif;
        background: radial-gradient(circle at top, var(--bg-cream) 0%, var(--bg-cream-dark) 100%);
        color: var(--text-dark);
        min-height: 100vh;
        overflow-x: hidden;
        position: relative;
        line-height: 1.5;
      }

      /* Dekoratif Arka Plan Yaprak Desenleri */
      body::before, body::after {
        content: '';
        position: absolute;
        width: 400px;
        height: 400px;
        opacity: 0.05;
        background-image: radial-gradient(var(--brand-olive) 1.5px, transparent 1px);
        background-size: 32px 32px;
        pointer-events: none;
        z-index: 0;
      }
      body::before { top: 2%; left: -100px; }
      body::after { bottom: 10%; right: -100px; }

      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 1.5rem;
        position: relative;
        z-index: 1;
      }

      /* Header Tasarımı */
      header {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        margin-bottom: 3.5rem;
        animation: fadeInDown 0.8s ease-out;
      }

      .logo-wrapper {
        position: relative;
        display: inline-block;
        margin-bottom: 1.5rem;
      }

      .logo-ring {
        position: absolute;
        top: -8px;
        left: -8px;
        right: -8px;
        bottom: -8px;
        border: 2px dashed rgba(212, 175, 55, 0.35);
        border-radius: 50%;
        animation: rotate 50s linear infinite;
      }

      .logo-img {
        width: 130px;
        height: 130px;
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid var(--brand-gold);
        box-shadow: 0 10px 30px rgba(212, 175, 55, 0.15);
      }

      h1 {
        font-size: 2.8rem;
        font-weight: 700;
        letter-spacing: -1px;
        color: var(--text-dark);
        margin-bottom: 0.2rem;
      }

      h1 span {
        color: var(--brand-gold-dark);
      }

      .slogan {
        font-size: 1.15rem;
        font-weight: 400;
        font-style: italic;
        color: var(--brand-olive);
        letter-spacing: 1px;
      }

      .divider {
        width: 80px;
        height: 3px;
        background: linear-gradient(90deg, transparent, var(--brand-gold), transparent);
        margin: 1.5rem auto 1rem;
      }

      /* Tanıtım / Hoş Geldiniz Kartı */
      .intro-card {
        background: rgba(255, 255, 255, 0.4);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(212, 175, 55, 0.15);
        border-radius: 24px;
        padding: 2rem;
        text-align: center;
        max-width: 800px;
        margin: 0 auto 4rem;
        box-shadow: 0 15px 45px rgba(44, 37, 32, 0.03);
        animation: fadeInUp 0.8s ease-out;
      }

      .intro-card p {
        font-size: 1.1rem;
        color: var(--text-muted);
        line-height: 1.7;
      }

      /* Bölüm Başlıkları */
      .section-title {
        text-align: center;
        font-size: 2rem;
        font-weight: 700;
        color: var(--text-dark);
        margin-bottom: 2.5rem;
        position: relative;
      }

      .section-title span {
        color: var(--brand-gold-dark);
      }

      .section-title::after {
        content: '';
        display: block;
        width: 50px;
        height: 3px;
        background: var(--brand-gold);
        margin: 0.7rem auto 0;
        border-radius: 2px;
      }

      /* Ürün Izgarası (Products Grid) */
      .products-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 2.5rem;
        margin-bottom: 5rem;
        animation: fadeInUp 1s ease-out;
      }

      @media (min-width: 992px) {
        /* Ürün tek veya iki taneyse çok yayılmaması için ortalıyoruz */
        .products-grid {
          display: flex;
          justify-content: center;
          flex-wrap: wrap;
        }
        .product-card {
          flex: 1 1 360px;
          max-width: 380px;
        }
      }

      /* Ürün Kartı (Glassmorphic Card) */
      .product-card {
        background: rgba(255, 255, 255, 0.45);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(212, 175, 55, 0.18);
        border-radius: 24px;
        padding: 1.8rem;
        display: flex;
        flex-direction: column;
        box-shadow: 0 20px 50px rgba(44, 37, 32, 0.04);
        transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1), box-shadow 0.4s ease;
        position: relative;
        overflow: hidden;
      }

      .product-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 30px 60px rgba(212, 175, 55, 0.12);
        border-color: rgba(212, 175, 55, 0.35);
      }

      /* Viral / Yeni Ürün Rozeti */
      .badge {
        position: absolute;
        top: 15px;
        right: 15px;
        background: linear-gradient(135deg, var(--brand-gold) 0%, var(--brand-gold-dark) 100%);
        color: white;
        padding: 0.4rem 1rem;
        border-radius: 50px;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.5px;
        box-shadow: 0 5px 15px rgba(212, 175, 55, 0.3);
        z-index: 2;
      }

      /* Ürün Görsel Çerçevesi */
      .product-img-wrapper {
        position: relative;
        border-radius: 18px;
        overflow: hidden;
        aspect-ratio: 4/3;
        margin-bottom: 1.5rem;
        border: 1px solid rgba(212, 175, 55, 0.1);
        background: #FDFDFD;
      }

      .product-img-wrapper::after {
        content: '';
        position: absolute;
        top: 8px;
        left: 8px;
        right: 8px;
        bottom: 8px;
        border: 1px dashed rgba(212, 175, 55, 0.2);
        border-radius: 12px;
        pointer-events: none;
      }

      .product-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
      }

      .product-card:hover .product-img {
        transform: scale(1.05);
      }

      .product-info {
        flex-grow: 1;
        display: flex;
        flex-direction: column;
      }

      .product-name {
        font-size: 1.6rem;
        font-weight: 700;
        color: var(--text-dark);
        margin-bottom: 0.5rem;
        letter-spacing: -0.5px;
      }

      /* Fiyat Tasarımı */
      .price-box {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        margin-bottom: 1.2rem;
      }

      .price-old {
        font-size: 1.1rem;
        color: var(--text-muted);
        text-decoration: line-through;
        opacity: 0.7;
      }

      .price-sale {
        font-size: 1.8rem;
        font-weight: 800;
        color: var(--brand-gold-dark);
        letter-spacing: -0.5px;
      }

      /* Özellikler Listesi */
      .features-list {
        list-style: none;
        margin-bottom: 1.8rem;
        flex-grow: 1;
      }

      .features-list li {
        font-size: 0.95rem;
        color: var(--text-muted);
        margin-bottom: 0.6rem;
        display: flex;
        align-items: flex-start;
        gap: 0.6rem;
        text-align: left;
        line-height: 1.4;
      }

      .features-list li .bullet {
        color: var(--brand-gold);
        font-weight: bold;
        flex-shrink: 0;
        margin-top: 1px;
      }

      /* YouTube Video Alanı */
      .video-box {
        position: relative;
        width: 100%;
        aspect-ratio: 16/9;
        border-radius: 14px;
        overflow: hidden;
        margin-bottom: 1.5rem;
        border: 1px solid rgba(212, 175, 55, 0.15);
        box-shadow: 0 8px 20px rgba(44, 37, 32, 0.05);
      }

      .video-box iframe {
        width: 100%;
        height: 100%;
        border: none;
      }

      /* Sipariş CTA Butonu */
      .btn-order {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.8rem;
        padding: 1.1rem 2rem;
        background: linear-gradient(135deg, var(--brand-gold) 0%, var(--brand-gold-dark) 100%);
        color: white;
        text-decoration: none;
        border-radius: 14px;
        font-weight: 700;
        font-size: 1.05rem;
        box-shadow: 0 10px 25px rgba(212, 175, 55, 0.25);
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        overflow: hidden;
        border: none;
        cursor: pointer;
        z-index: 1;
      }

      .btn-order::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 50%;
        height: 100%;
        background: linear-gradient(
          to right,
          rgba(255, 255, 255, 0) 0%,
          rgba(255, 255, 255, 0.3) 50%,
          rgba(255, 255, 255, 0) 100%
        );
        transform: skewX(-25deg);
        transition: 0.75s;
        z-index: -1;
      }

      .btn-order:hover::before {
        left: 150%;
        transition: 0.75s;
      }

      .btn-order:hover {
        transform: translateY(-3px);
        box-shadow: 0 15px 30px rgba(212, 175, 55, 0.35);
      }

      .btn-order:active {
        transform: translateY(-1px);
      }

      .btn-order svg {
        transition: transform 0.3s ease;
      }

      .btn-order:hover svg {
        transform: translateX(4px);
      }


      /* Boş Durum (Empty State) Tasarımı */
      .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        background: rgba(255, 255, 255, 0.4);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(212, 175, 55, 0.15);
        border-radius: 24px;
        max-width: 600px;
        margin: 2rem auto;
        box-shadow: 0 15px 45px rgba(44, 37, 32, 0.02);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        animation: fadeInUp 0.8s ease-out;
      }

      .empty-state .icon {
        font-size: 3.5rem;
        animation: pulse 2s infinite ease-in-out;
      }

      .empty-state h3 {
        font-size: 1.8rem;
        font-weight: 700;
        color: var(--text-dark);
      }

      .empty-state p {
        font-size: 1.05rem;
        color: var(--text-muted);
        line-height: 1.6;
        max-width: 450px;
      }

      .btn-follow {
        display: inline-block;
        padding: 0.9rem 2rem;
        background: linear-gradient(135deg, var(--brand-olive) 0%, var(--brand-olive-light) 100%);
        color: white;
        text-decoration: none;
        border-radius: 12px;
        font-weight: 600;
        font-size: 1rem;
        box-shadow: 0 8px 20px rgba(85, 107, 47, 0.2);
        transition: all 0.3s ease;
        margin-top: 0.5rem;
      }

      .btn-follow:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 25px rgba(85, 107, 47, 0.35);
      }

      @keyframes pulse {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.08); }
      }

      /* SIPARIŞ ADIMLARI (Instagram Satış Akışı) */
      .order-steps-section {
        margin: 6rem auto 5rem;
        max-width: 950px;
        text-align: center;
      }

      .steps-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 2rem;
        margin-top: 3rem;
      }

      .step-card {
        background: rgba(255, 255, 255, 0.35);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(212, 175, 55, 0.12);
        border-radius: 20px;
        padding: 2rem 1.5rem;
        position: relative;
        box-shadow: 0 10px 30px rgba(44, 37, 32, 0.02);
      }

      .step-number {
        width: 45px;
        height: 45px;
        background: linear-gradient(135deg, var(--brand-gold) 0%, var(--brand-gold-dark) 100%);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        font-weight: 800;
        margin: 0 auto 1.2rem;
        box-shadow: 0 5px 15px rgba(212, 175, 55, 0.25);
      }

      .step-card h4 {
        font-size: 1.2rem;
        font-weight: 600;
        color: var(--text-dark);
        margin-bottom: 0.6rem;
      }

      .step-card p {
        font-size: 0.95rem;
        color: var(--text-muted);
        line-height: 1.5;
      }

      /* DEĞERLERİMİZ (Neden Biz?) */
      .values-section {
        background: rgba(85, 107, 47, 0.05);
        border: 1px solid rgba(85, 107, 47, 0.1);
        border-radius: 24px;
        padding: 3rem 2rem;
        margin-bottom: 5rem;
        text-align: center;
      }

      .values-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 2.5rem;
        margin-top: 2.5rem;
      }

      .value-item h4 {
        font-size: 1.25rem;
        color: var(--brand-olive);
        margin-bottom: 0.8rem;
        font-weight: 600;
      }

      .value-item p {
        font-size: 0.95rem;
        color: var(--text-muted);
        line-height: 1.6;
      }

      /* SSS (FAQ) Accordion Tasarımı */
      .faq-section {
        max-width: 850px;
        margin: 6rem auto 5rem;
        padding: 0 1.5rem;
        text-align: center;
      }
      
      .faq-list {
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
        margin-top: 2.5rem;
        text-align: left;
      }
      
      .faq-item {
        background: rgba(255, 255, 255, 0.45);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(212, 175, 55, 0.18);
        border-radius: 16px;
        overflow: hidden;
        transition: all 0.3s ease;
      }
      
      .faq-item:hover {
        border-color: rgba(212, 175, 55, 0.4);
        box-shadow: 0 10px 25px rgba(212, 175, 55, 0.08);
      }
      
      .faq-item details {
        padding: 1.2rem 1.5rem;
      }
      
      .faq-item summary {
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--text-dark);
        list-style: none;
        display: flex;
        justify-content: space-between;
        align-items: center;
        cursor: pointer;
        outline: none;
        user-select: none;
      }
      
      .faq-item summary::-webkit-details-marker {
        display: none;
      }
      
      .faq-item summary::after {
        content: '＋';
        font-size: 1.2rem;
        color: var(--brand-gold-dark);
        transition: transform 0.3s ease;
        font-weight: bold;
      }
      
      .faq-item details[open] summary::after {
        content: '－';
        transform: rotate(180deg);
      }
      
      .faq-content {
        margin-top: 1rem;
        color: var(--text-muted);
        font-size: 0.98rem;
        line-height: 1.6;
        padding-top: 0.8rem;
        border-top: 1px dashed rgba(212, 175, 55, 0.15);
        animation: slideDown 0.3s ease-out;
      }

      /* Altbilgi (Footer) */
      footer {
        text-align: center;
        padding: 3rem 0;
        margin-top: auto;
        border-top: 1px solid rgba(212, 175, 55, 0.1);
        color: var(--text-muted);
        font-size: 0.9rem;
      }

      footer .social-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--brand-gold-dark);
        text-decoration: none;
        font-weight: 600;
        font-size: 1.05rem;
        margin-bottom: 1.5rem;
        transition: color 0.3s ease;
      }

      footer .social-link:hover {
        color: var(--brand-olive);
      }

      footer .copyright {
        opacity: 0.75;
      }

      /* Animasyonlar */
      @keyframes rotate {
        100% { transform: rotate(360deg); }
      }

      @keyframes fadeInDown {
        from { opacity: 0; transform: translateY(-30px); }
        to { opacity: 1; transform: translateY(0); }
      }

      @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
      }

      @keyframes slideDown {
        from { opacity: 0; transform: translateY(-10px); }
        to { opacity: 1; transform: translateY(0); }
      }

      /* ========================================== */
      /* NEW PREMIUM FEATURES: TOASTS, CART, MODALS */
      /* ========================================== */

      /* Toast Notification Container */
      #toast-container {
        position: fixed;
        top: 24px;
        right: 24px;
        z-index: 9999;
        display: flex;
        flex-direction: column;
        gap: 12px;
        max-width: 380px;
        width: calc(100% - 48px);
        pointer-events: none;
      }

      .toast {
        background: rgba(255, 255, 255, 0.92);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-left: 4px solid var(--brand-gold);
        border-top: 1px solid rgba(212, 175, 55, 0.2);
        border-bottom: 1px solid rgba(212, 175, 55, 0.2);
        border-right: 1px solid rgba(212, 175, 55, 0.2);
        color: var(--text-dark);
        padding: 1rem 1.25rem;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(44, 37, 32, 0.08);
        display: flex;
        align-items: center;
        gap: 0.8rem;
        font-weight: 500;
        font-size: 0.95rem;
        pointer-events: auto;
        transform: translateX(120%);
        transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.15), opacity 0.4s ease;
        opacity: 0;
      }

      .toast.show {
        transform: translateX(0);
        opacity: 1;
      }

      .toast.success {
        border-left-color: var(--brand-olive);
      }

      .toast-icon {
        font-size: 1.2rem;
        flex-shrink: 0;
      }

      /* Floating Cart Button */
      .floating-cart {
        position: fixed;
        bottom: 30px;
        right: 30px;
        z-index: 1000;
        background: linear-gradient(135deg, var(--brand-gold) 0%, var(--brand-gold-dark) 100%);
        color: white;
        border: none;
        width: 65px;
        height: 65px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 10px 30px rgba(212, 175, 55, 0.35);
        cursor: pointer;
        transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.3s ease;
      }

      .floating-cart:hover {
        transform: scale(1.1) translateY(-3px);
        box-shadow: 0 15px 35px rgba(212, 175, 55, 0.45);
      }

      .floating-cart:active {
        transform: scale(0.95);
      }

      .cart-icon-wrapper {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .cart-icon {
        font-size: 1.6rem;
      }

      .cart-count {
        position: absolute;
        top: -10px;
        right: -10px;
        background: var(--brand-olive);
        color: white;
        font-size: 0.75rem;
        font-weight: 800;
        width: 22px;
        height: 22px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 3px 10px rgba(85, 107, 47, 0.3);
        border: 2px solid white;
        transition: transform 0.3s ease;
      }

      .cart-count.bump {
        animation: bounce 0.4s ease-out;
      }

      /* Modals and Drawers */
      .modal, .drawer {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        z-index: 2000;
        display: none;
        overflow: hidden;
      }

      .modal-backdrop, .drawer-backdrop {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(44, 37, 32, 0.4);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        opacity: 0;
        transition: opacity 0.4s ease;
      }

      /* Product Detail Modal (Centered) */
      .modal-content {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -40%) scale(0.95);
        background: radial-gradient(circle at top, var(--bg-cream) 0%, var(--bg-cream-dark) 100%);
        border: 1px solid rgba(212, 175, 55, 0.25);
        border-radius: 28px;
        width: 90%;
        max-width: 850px;
        max-height: 85vh;
        overflow-y: auto;
        box-shadow: 0 30px 70px rgba(44, 37, 32, 0.15);
        opacity: 0;
        transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1), opacity 0.4s ease;
        padding: 2.5rem;
      }

      .modal.show, .drawer.show {
        display: block;
      }

      .modal.show .modal-backdrop, .drawer.show .drawer-backdrop {
        opacity: 1;
      }

      .modal.show .modal-content {
        transform: translate(-50%, -50%) scale(1);
        opacity: 1;
      }

      /* Close buttons */
      .modal-close, .drawer-close {
        position: absolute;
        top: 20px;
        right: 20px;
        background: rgba(255, 255, 255, 0.5);
        border: 1px solid rgba(212, 175, 55, 0.2);
        color: var(--text-dark);
        width: 40px;
        height: 40px;
        border-radius: 50%;
        font-size: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        z-index: 10;
        transition: background 0.3s ease, transform 0.3s ease;
      }

      .modal-close:hover, .drawer-close:hover {
        background: var(--brand-gold);
        color: white;
        transform: rotate(90deg);
      }

      /* Cart Drawer (Slides from Right) */
      .drawer-content {
        position: absolute;
        top: 0;
        right: 0;
        width: 100%;
        max-width: 480px;
        height: 100%;
        background: radial-gradient(circle at top, var(--bg-cream) 0%, var(--bg-cream-dark) 100%);
        border-left: 1px solid rgba(212, 175, 55, 0.25);
        box-shadow: -20px 0 60px rgba(44, 37, 32, 0.08);
        transform: translateX(100%);
        transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        display: flex;
        flex-direction: column;
      }

      .drawer.show .drawer-content {
        transform: translateX(0);
      }

      .drawer-header {
        padding: 1.8rem 2rem;
        border-bottom: 1px solid rgba(212, 175, 55, 0.15);
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .drawer-header h3 {
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--text-dark);
      }

      .drawer-body {
        padding: 1.8rem 2rem;
        overflow-y: auto;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
      }

      /* Cart Items */
      .cart-items-list {
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
        margin-bottom: 2rem;
      }

      .cart-item {
        display: flex;
        gap: 1rem;
        align-items: center;
        background: rgba(255, 255, 255, 0.4);
        border: 1px solid rgba(212, 175, 55, 0.12);
        padding: 0.8rem 1rem;
        border-radius: 16px;
      }

      .cart-item-img {
        width: 70px;
        height: 70px;
        border-radius: 12px;
        object-fit: cover;
        border: 1px solid rgba(212, 175, 55, 0.1);
        background: white;
      }

      .cart-item-info {
        flex-grow: 1;
      }

      .cart-item-name {
        font-size: 1rem;
        font-weight: 700;
        color: var(--text-dark);
        margin-bottom: 0.2rem;
      }

      .cart-item-price {
        font-size: 1rem;
        font-weight: 600;
        color: var(--brand-gold-dark);
      }

      .cart-item-controls {
        display: flex;
        align-items: center;
        gap: 0.6rem;
      }

      .btn-qty {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        border: 1px solid rgba(212, 175, 55, 0.25);
        background: rgba(255, 255, 255, 0.6);
        color: var(--text-dark);
        font-weight: bold;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.9rem;
        transition: all 0.2s ease;
      }

      .btn-qty:hover {
        background: var(--brand-gold);
        color: white;
        border-color: var(--brand-gold);
      }

      .qty-val {
        font-size: 1rem;
        font-weight: 700;
        min-width: 20px;
        text-align: center;
      }

      .btn-remove {
        background: none;
        border: none;
        color: #c0392b;
        cursor: pointer;
        font-size: 1.1rem;
        padding: 4px;
        margin-left: 0.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.2s ease;
      }

      .btn-remove:hover {
        transform: scale(1.15);
      }

      /* Cart Footer */
      .cart-summary {
        margin-top: auto;
        padding-top: 1.5rem;
        border-top: 1px dashed rgba(212, 175, 55, 0.2);
      }

      .summary-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.2rem;
      }

      .summary-label {
        font-size: 1.1rem;
        font-weight: 500;
        color: var(--text-muted);
      }

      .summary-value {
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--brand-gold-dark);
      }

      .btn-checkout-start, .btn-submit-order {
        position: relative;
        overflow: hidden;
        z-index: 1;
        width: 100%;
        padding: 1.1rem 2rem;
        background: linear-gradient(135deg, var(--brand-gold) 0%, var(--brand-gold-dark) 100%);
        color: white;
        border: none;
        border-radius: 14px;
        font-size: 1.05rem;
        font-weight: 700;
        cursor: pointer;
        box-shadow: 0 10px 25px rgba(212, 175, 55, 0.2);
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.8rem;
      }

      /* Premium Light-Sweep Shimmer Effect */
      .btn-checkout-start::before, .btn-submit-order::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 50%;
        height: 100%;
        background: linear-gradient(
          to right,
          rgba(255, 255, 255, 0) 0%,
          rgba(255, 255, 255, 0.3) 50%,
          rgba(255, 255, 255, 0) 100%
        );
        transform: skewX(-25deg);
        transition: 0.75s;
        z-index: -1;
      }

      .btn-checkout-start:hover::before, .btn-submit-order:hover::before {
        left: 150%;
        transition: 0.75s;
      }

      .btn-checkout-start:hover, .btn-submit-order:hover {
        transform: translateY(-3px);
        box-shadow: 0 15px 30px rgba(212, 175, 55, 0.35);
      }

      .btn-checkout-start:active, .btn-submit-order:active {
        transform: translateY(-1px);
      }

      /* SVG Arrow Translate on Hover */
      .btn-checkout-start svg, .btn-submit-order svg {
        transition: transform 0.3s ease;
      }

      .btn-checkout-start:hover svg, .btn-submit-order:hover svg {
        transform: translateX(4px);
      }

      /* Premium Checkout Form */
      .checkout-form {
        display: flex;
        flex-direction: column;
        gap: 1.1rem;
        animation: slideDown 0.4s ease-out;
      }

      .form-section-title {
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--brand-olive);
        margin-bottom: 0.4rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
      }

      .form-group label {
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--text-dark);
      }

      .form-control {
        padding: 0.85rem 1.1rem;
        border-radius: 12px;
        border: 1px solid rgba(212, 175, 55, 0.25);
        background: rgba(255, 255, 255, 0.7);
        font-family: inherit;
        font-size: 0.95rem;
        color: var(--text-dark);
        outline: none;
        transition: all 0.3s ease;
      }

      .form-control:focus {
        border-color: var(--brand-gold-dark);
        background: white;
        box-shadow: 0 0 10px rgba(212, 175, 55, 0.15);
      }

      .form-control.invalid {
        border-color: #e74c3c;
        background: rgba(231, 76, 60, 0.05);
      }

      .error-msg {
        font-size: 0.8rem;
        color: #e74c3c;
        font-weight: 500;
        margin-top: -2px;
        display: none;
      }

      .form-control.invalid + .error-msg {
        display: block;
      }

      .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
      }

      .btn-back {
        background: none;
        border: 1px solid rgba(212, 175, 55, 0.3);
        color: var(--text-muted);
        padding: 0.5rem 1rem;
        border-radius: 10px;
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        align-self: flex-start;
        margin-bottom: 1rem;
        transition: all 0.2s ease;
      }

      .btn-back:hover {
        background: rgba(212, 175, 55, 0.1);
        color: var(--text-dark);
      }

      /* Image Slideshow / Gallery */
      .slideshow-container {
        position: relative;
        width: 100%;
        max-width: 450px;
        margin: 0 auto 1.5rem;
        border-radius: 20px;
        overflow: hidden;
        aspect-ratio: 4/3;
        border: 1px solid rgba(212, 175, 55, 0.15);
        box-shadow: 0 10px 25px rgba(44, 37, 32, 0.04);
      }

      .slide-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: none;
      }

      .slide-img.active {
        display: block;
        animation: fadeEffect 0.5s ease-in-out;
      }

      .slide-btn {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(5px);
        border: 1px solid rgba(212, 175, 55, 0.2);
        color: var(--text-dark);
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        cursor: pointer;
        user-select: none;
        transition: all 0.2s ease;
        z-index: 2;
      }

      .slide-btn:hover {
        background: var(--brand-gold);
        color: white;
      }

      .slide-prev { left: 10px; }
      .slide-next { right: 10px; }

      .slide-dots {
        position: absolute;
        bottom: 15px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        gap: 6px;
        z-index: 2;
      }

      .dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.5);
        cursor: pointer;
        transition: all 0.3s ease;
      }

      .dot.active {
        background: var(--brand-gold);
        width: 18px;
        border-radius: 4px;
      }

      /* Modal Grid Layout */
      .modal-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
      }

      @media (min-width: 768px) {
        .modal-grid {
          grid-template-columns: 1.1fr 1.2fr;
        }
      }

      .modal-right {
        display: flex;
        flex-direction: column;
      }

      .modal-title {
        font-size: 1.8rem;
        font-weight: 700;
        color: var(--text-dark);
        margin-bottom: 0.5rem;
      }

      .modal-desc {
        color: var(--text-muted);
        font-size: 1rem;
        line-height: 1.6;
        margin-bottom: 1.5rem;
      }

      .modal-actions {
        display: flex;
        flex-direction: column;
        gap: 0.8rem;
        margin-top: auto;
        padding-top: 1.5rem;
        border-top: 1px dashed rgba(212, 175, 55, 0.15);
      }

      .btn-modal-add {
        width: 100%;
        padding: 1.1rem;
        background: linear-gradient(135deg, var(--brand-gold) 0%, var(--brand-gold-dark) 100%);
        color: white;
        border: none;
        border-radius: 14px;
        font-weight: 700;
        font-size: 1.05rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.8rem;
        box-shadow: 0 8px 20px rgba(212, 175, 55, 0.2);
        transition: all 0.3s ease;
      }

      .btn-modal-add:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 25px rgba(212, 175, 55, 0.3);
      }

      .btn-modal-instant {
        width: 100%;
        padding: 1.1rem;
        background: rgba(85, 107, 47, 0.1);
        border: 1px solid rgba(85, 107, 47, 0.3);
        color: var(--brand-olive);
        border-radius: 14px;
        font-weight: 700;
        font-size: 1.05rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.8rem;
        transition: all 0.3s ease;
      }

      .btn-modal-instant:hover {
        background: var(--brand-olive);
        color: white;
      }

      /* Empty Cart View */
      .empty-cart-view {
        text-align: center;
        padding: 3rem 1rem;
        margin: auto;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
      }

      .empty-cart-icon {
        font-size: 3rem;
        filter: grayscale(0.2);
      }

      .empty-cart-text {
        color: var(--text-muted);
        font-size: 1.05rem;
        line-height: 1.5;
      }

      /* Modal Videos Area */
      .modal-videos-title {
        font-size: 1.15rem;
        font-weight: 700;
        color: var(--brand-olive);
        margin: 1.5rem 0 0.8rem;
      }

      .modal-videos-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        margin-bottom: 1.5rem;
      }

      .modal-video-item {
        position: relative;
        width: 100%;
        aspect-ratio: 16/9;
        border-radius: 14px;
        overflow: hidden;
        border: 1px solid rgba(212, 175, 55, 0.15);
      }

      .modal-video-item iframe {
        width: 100%;
        height: 100%;
        border: none;
      }

      /* Prevent background scroll when modal open */
      body.modal-open {
        overflow: hidden;
      }

      /* Product Card Pointer */
      .product-card {
        cursor: pointer;
      }

      /* Bounce Keyframe */
      @keyframes bounce {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.3); }
      }

      @keyframes fadeEffect {
        from { opacity: 0.4; }
        to { opacity: 1; }
      }
    </style>
  </head>
  <body>
    <div class="container">
      
      <!-- Üstbilgi (Header) -->
      <header>
        <div class="logo-wrapper">
          <div class="logo-ring"></div>
          <img src="/images/logo.jpg" alt="ES Yaşam Logo" class="logo-img" />
        </div>
        <h1>ES <span>Yaşam</span></h1>
        <p class="slogan">"Daha güzel bir yaşam için"</p>
        <div class="divider"></div>
      </header>

      <!-- Hoş Geldiniz Açıklaması -->
      <section class="intro-card">
        <p>
          Doğadan ilham alan, lüks formüllere sahip temizlik ürünlerimizle tanışın. Stoklarımız her zaman güncel tutulmaktadır. En iyi ve ekonomik ürünleri size en uygun şekilde sunma gayretindeyiz. Ürünlerimizin özelliklerini ve kullanım videolarını aşağıda inceleyebilir, sipariş için doğrudan Instagram DM üzerinden bizimle iletişime geçebilirsiniz!
        </p>
      </section>

      <!-- Ürünler Alanı -->
      <section id="products">
        <h2 class="section-title">Lansman <span>Ürünlerimiz</span></h2>
        
        <div class="products-grid">
          {products.length === 0 ? (
            <div class="empty-state">
              <span class="icon">🌿</span>
              <h3>Yepyeni Ürünlerimiz Pek Yakında!</h3>
              <p>Doğal temizlik ve ferahlık sunan lansman ürünlerimiz hazırlanıyor. Güncel ürünlerimizi ve viral videolarımızı çok yakında burada görebilirsiniz.</p>
              <a href="https://instagram.com/es_yasam" target="_blank" class="btn-follow">Instagram'da Takip Edin</a>
            </div>
          ) : (
            products.map((product, index) => {
              const resolvedImg = resolveProductImage(product.image, product.id);
              const embedVideo = getYoutubeEmbedUrl(product.video);
              
              // Eski (üzeri çizili) fiyat ve indirimli (yeni) satış fiyatı ayarı:
              // Eğer veritabanından 'campaignPrice' (Yeni_Fiyati) geliyorsa ve 0'dan büyükse onu indirimli fiyat yapıyoruz,
              // 'salePrice' (Satis_Fiyati) ise üzeri çizili eski fiyat oluyor.
              const campaignPriceNum = parseFloat(product.campaignPrice);
              const salePriceNum = parseFloat(product.salePrice) || 0;
              const hasCampaign = !isNaN(campaignPriceNum) && campaignPriceNum > 0 && campaignPriceNum < salePriceNum;
              
              const currentPrice = hasCampaign ? campaignPriceNum : salePriceNum;
              const originalPrice = hasCampaign ? salePriceNum : null;
              
              return (
                <a 
                  href={`/urun/${product.id}`}
                  class="product-card" 
                  id={`product-${product.id}`}
                  style="text-decoration: none;"
                >
                  {/* Rozet */}
                  <div class="badge">VİRAL ÜRÜN</div>
                  
                  {/* Ürün Görseli */}
                  <div class="product-img-wrapper">
                    <img 
                      src={resolvedImg} 
                      alt={product.name} 
                      class="product-img" 
                      loading={index === 0 ? "eager" : "lazy"} 
                      fetchpriority={index === 0 ? "high" : "auto"}
                    />
                  </div>
                  
                  <div class="product-info">
                    {/* Başlık ve Fiyat */}
                    <h3 class="product-name">{product.name}</h3>
                    
                    <div class="price-box">
                      {originalPrice && <span class="price-old">{originalPrice} TL</span>}
                      <span class="price-sale">{currentPrice} TL</span>
                    </div>
                    
                    {/* Detaylar / Özellikler */}
                    <ul class="features-list">
                      {product.features.split('\n').filter(Boolean).slice(0, 3).map(feature => (
                        <li>
                          <span class="bullet">✦</span>
                          <span>{feature.replace(/^[✓\s*-]+/, '')}</span>
                        </li>
                      ))}
                    </ul>
                    
                    {/* Sepete Ekle CTA */}
