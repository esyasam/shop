// ES Yaşam - Premium Tek Sayfalık E-Ticaret Vitrini (Instagram Satış Sayfası Tasarımı)
import fs from 'node:fs';
import path from 'node:path';
import CartDrawer from '../components/CartDrawer.astro';

const databaseUrl = "https://esyasam77-default-rtdb.europe-west1.firebasedatabase.app";
const url = `${databaseUrl}/products.json`;

let products = [];
let dbError = false;

try {
  const response = await fetch(url);
  if (response.ok) {
    const data = await response.json();
    if (data) {
      products = Object.values(data);
    }
  } else {
    dbError = true;
  }
} catch (error) {
  console.error("Firebase veritabanından ürünler çekilirken hata oluştu:", error);
  dbError = true;
}


/**
 * YouTube linklerini (Shorts dahil) otomatik olarak embed koduna çeviren akıllı yardımcı fonksiyon.
 */
function getYoutubeEmbedUrl(url) {
  if (!url) return null;
  let videoId = "";
  
  if (url.includes("youtube.com/shorts/")) {
    videoId = url.split("youtube.com/shorts/")[1].split("?")[0].split("&")[0];
  } else if (url.includes("youtu.be/")) {
    videoId = url.split("youtu.be/")[1].split("?")[0].split("&")[0];
  } else if (url.includes("v=")) {
    videoId = url.split("v=")[1].split("&")[0];
  } else if (url.length === 11) {
    videoId = url;
  }
  
  return videoId ? `https://www.youtube.com/embed/${videoId}` : null;
}

/**
 * E-tablodaki resim isimlerini veya boş yolları akıllı klasör yapımızla eşleyen yardımcı fonksiyon.
 */
function resolveProductImage(image, id) {
  // 1. Ürün ID'si ile eşleşen bir görselin direkt public/images altında olup olmadığını kontrol et (ör. 50200.webp, 50505.webp)
  try {
    const idPath = path.join(process.cwd(), 'public', 'images', `${id}.webp`);
    if (fs.existsSync(idPath)) {
      return `/images/${id}.webp`;
    }
  } catch (e) {
    // ignore
  }

  // 2. Belirtilen görsel adının direkt public/images altında olup olmadığını kontrol et
  if (image && !image.includes("/")) {
    try {
      const directPath = path.join(process.cwd(), 'public', 'images', image);
      if (fs.existsSync(directPath)) {
        return `/images/${image}`;
      }
    } catch (e) {
      // ignore
    }
  }

  // 3. Resmi bulunmayan ürünler için stok_logo.webp kontrolü ve fallback kullanımı
  try {
    const defaultLogoPath = path.join(process.cwd(), 'public', 'images', 'stok_logo.webp');
    if (fs.existsSync(defaultLogoPath)) {
      return '/images/stok_logo.webp';
    }
  } catch (e) {
    // ignore
  }

  // 4. Klasik/eski eşleme mantığı (fallback)
  if (!image) {
    return `/images/products/${id}/cover.webp`;
  }
  if (!image.includes("/")) {
    return `/images/products/${id}/${image}`;
  }
  return image;
}

/**
 * Ürüne özel, sürtünmesiz direkt Instagram DM mesaj linki oluşturan yardımcı fonksiyon.
 */
function getInstagramDmUrl(productName, customLink) {
  if (customLink && customLink.trim() !== "") {
    return customLink;
  }
  const baseText = `Merhaba, ES Yaşam ${productName} ürününüz hakkında bilgi almak ve sipariş vermek istiyorum!`;
  return `https://ig.me/m/es_yasam?text=${encodeURIComponent(baseText)}`;
}
---

<html lang="tr">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO Meta Etiketleri -->
    <title>ES Yaşam - Daha güzel bir yaşam için | Premium Mağaza</title>
    <meta name="description" content="Leke Çıkartıcı, Sarı Güç ve Mavi Güç lansman ürünlerimiz için hazırlanan ultra-premium, yüksek dönüşümlü e-ticaret satış sayfamız. Tüm ürünlerimizi inceleyin ve Instagram @es_yasam üzerinden kolayca sipariş verin." />
    <meta name="robots" content="index, follow" />
    
    <!-- Open Graph (Sosyal Medya Paylaşım ve Önizleme Kartları) -->
    <meta property="og:title" content="ES Yaşam - Daha güzel bir yaşam için" />
    <meta property="og:description" content="Doğadan ilham alan lüks formüllü temizlik ürünlerimizle tanışın. Stoklarımız her zaman güncel tutulmaktadır. Instagram DM üzerinden kolayca sipariş verin!" />
    <meta property="og:image" content="https://esyasam.com/images/logo.jpg" />
    <meta property="og:url" content="https://esyasam.com" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ES Yaşam" />
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style>
      :root {
        --brand-gold: #d4af37;
        --brand-gold-dark: #c5a028;
        --brand-olive: #556b2f;
        --brand-olive-light: #8fbc8f;
        --bg-cream: #FAF8F5;
        --bg-cream-dark: #F5F2EB;
        --text-dark: #2c2520;
        --text-muted: #6e645e;
      }

      /* Premium Custom Scrollbars */
      ::-webkit-scrollbar {
        width: 8px;
        height: 8px;
      }
      ::-webkit-scrollbar-track {
        background: var(--bg-cream-dark);
      }
      ::-webkit-scrollbar-thumb {
        background: rgba(212, 175, 55, 0.3);
        border-radius: 10px;
        border: 2px solid var(--bg-cream-dark);
        transition: background 0.3s ease;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: var(--brand-gold);
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family: 'Outfit', sans-serif;
        background: radial-gradient(circle at top, var(--bg-cream) 0%, var(--bg-cream-dark) 100%);
        color: var(--text-dark);
        min-height: 100vh;
        overflow-x: hidden;
        position: relative;
        line-height: 1.5;
      }

      /* Dekoratif Arka Plan Yaprak Desenleri */
      body::before, body::after {
        content: '';
        position: absolute;
        width: 400px;
        height: 400px;
        opacity: 0.05;
        background-image: radial-gradient(var(--brand-olive) 1.5px, transparent 1px);
        background-size: 32px 32px;
        pointer-events: none;
        z-index: 0;
      }
      body::before { top: 2%; left: -100px; }
      body::after { bottom: 10%; right: -100px; }

      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 1.5rem;
        position: relative;
        z-index: 1;
      }

      /* Header Tasarımı */
      header {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        margin-bottom: 3.5rem;
        animation: fadeInDown 0.8s ease-out;
      }

      .logo-wrapper {
        position: relative;
        display: inline-block;
        margin-bottom: 1.5rem;
      }

      .logo-ring {
        position: absolute;
        top: -8px;
        left: -8px;
        right: -8px;
        bottom: -8px;
        border: 2px dashed rgba(212, 175, 55, 0.35);
        border-radius: 50%;
        animation: rotate 50s linear infinite;
      }

      .logo-img {
        width: 130px;
        height: 130px;
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid var(--brand-gold);
        box-shadow: 0 10px 30px rgba(212, 175, 55, 0.15);
      }

      h1 {
        font-size: 2.8rem;
        font-weight: 700;
        letter-spacing: -1px;
        color: var(--text-dark);
        margin-bottom: 0.2rem;
      }

      h1 span {
        color: var(--brand-gold-dark);
      }

      .slogan {
        font-size: 1.15rem;
        font-weight: 400;
        font-style: italic;
        color: var(--brand-olive);
        letter-spacing: 1px;
      }

      .divider {
        width: 80px;
        height: 3px;
        background: linear-gradient(90deg, transparent, var(--brand-gold), transparent);
        margin: 1.5rem auto 1rem;
      }

      /* Tanıtım / Hoş Geldiniz Kartı */
      .intro-card {
        background: rgba(255, 255, 255, 0.4);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(212, 175, 55, 0.15);
        border-radius: 24px;
        padding: 2rem;
        text-align: center;
        max-width: 800px;
        margin: 0 auto 4rem;
        box-shadow: 0 15px 45px rgba(44, 37, 32, 0.03);
        animation: fadeInUp 0.8s ease-out;
      }

      .intro-card p {
        font-size: 1.1rem;
        color: var(--text-muted);
        line-height: 1.7;
      }

      /* Bölüm Başlıkları */
      .section-title {
        text-align: center;
        font-size: 2rem;
        font-weight: 700;
        color: var(--text-dark);
        margin-bottom: 2.5rem;
        position: relative;
      }

      .section-title span {
        color: var(--brand-gold-dark);
      }

      .section-title::after {
        content: '';
        display: block;
        width: 50px;
        height: 3px;
        background: var(--brand-gold);
        margin: 0.7rem auto 0;
        border-radius: 2px;
      }

      /* Ürün Izgarası (Products Grid) */
      .products-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 2.5rem;
        margin-bottom: 5rem;
        animation: fadeInUp 1s ease-out;
      }

      @media (min-width: 992px) {
        /* Ürün tek veya iki taneyse çok yayılmaması için ortalıyoruz */
        .products-grid {
          display: flex;
          justify-content: center;
          flex-wrap: wrap;
        }
        .product-card {
          flex: 1 1 360px;
          max-width: 380px;
        }
      }

      /* Ürün Kartı (Glassmorphic Card) */
      .product-card {
        background: rgba(255, 255, 255, 0.45);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(212, 175, 55, 0.18);
        border-radius: 24px;
        padding: 1.8rem;
        display: flex;
        flex-direction: column;
        box-shadow: 0 20px 50px rgba(44, 37, 32, 0.04);
        transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1), box-shadow 0.4s ease;
        position: relative;
        overflow: hidden;
      }

      .product-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 30px 60px rgba(212, 175, 55, 0.12);
        border-color: rgba(212, 175, 55, 0.35);
      }

      /* Viral / Yeni Ürün Rozeti */
      .badge {
        position: absolute;
        top: 15px;
        right: 15px;
        background: linear-gradient(135deg, var(--brand-gold) 0%, var(--brand-gold-dark) 100%);
        color: white;
        padding: 0.4rem 1rem;
        border-radius: 50px;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.5px;
        box-shadow: 0 5px 15px rgba(212, 175, 55, 0.3);
        z-index: 2;
      }

      /* Ürün Görsel Çerçevesi */
      .product-img-wrapper {
        position: relative;
        border-radius: 18px;
        overflow: hidden;
        aspect-ratio: 4/3;
        margin-bottom: 1.5rem;
        border: 1px solid rgba(212, 175, 55, 0.1);
        background: #FDFDFD;
      }

      .product-img-wrapper::after {
        content: '';
        position: absolute;
        top: 8px;
        left: 8px;
        right: 8px;
        bottom: 8px;
        border: 1px dashed rgba(212, 175, 55, 0.2);
        border-radius: 12px;
        pointer-events: none;
      }

      .product-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
      }

      .product-card:hover .product-img {
        transform: scale(1.05);
      }

      .product-info {
        flex-grow: 1;
        display: flex;
        flex-direction: column;
      }

      .product-name {
        font-size: 1.6rem;
        font-weight: 700;
        color: var(--text-dark);
        margin-bottom: 0.5rem;
        letter-spacing: -0.5px;
      }

      /* Fiyat Tasarımı */
      .price-box {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        margin-bottom: 1.2rem;
      }

      .price-old {
        font-size: 1.1rem;
        color: var(--text-muted);
        text-decoration: line-through;
        opacity: 0.7;
      }

      .price-sale {
        font-size: 1.8rem;
        font-weight: 800;
        color: var(--brand-gold-dark);
        letter-spacing: -0.5px;
      }

      /* Özellikler Listesi */
      .features-list {
        list-style: none;
        margin-bottom: 1.8rem;
        flex-grow: 1;
      }

      .features-list li {
        font-size: 0.95rem;
        color: var(--text-muted);
        margin-bottom: 0.6rem;
        display: flex;
        align-items: flex-start;
        gap: 0.6rem;
        text-align: left;
        line-height: 1.4;
      }

      .features-list li .bullet {
        color: var(--brand-gold);
        font-weight: bold;
        flex-shrink: 0;
        margin-top: 1px;
      }

      /* YouTube Video Alanı */
      .video-box {
        position: relative;
        width: 100%;
        aspect-ratio: 16/9;
        border-radius: 14px;
        overflow: hidden;
        margin-bottom: 1.5rem;
        border: 1px solid rgba(212, 175, 55, 0.15);
        box-shadow: 0 8px 20px rgba(44, 37, 32, 0.05);
      }

      .video-box iframe {
        width: 100%;
        height: 100%;
        border: none;
      }

      /* Sipariş CTA Butonu */
      .btn-order {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.8rem;
        padding: 1.1rem 2rem;
        background: linear-gradient(135deg, var(--brand-gold) 0%, var(--brand-gold-dark) 100%);
        color: white;
        text-decoration: none;
        border-radius: 14px;
        font-weight: 700;
        font-size: 1.05rem;
        box-shadow: 0 10px 25px rgba(212, 175, 55, 0.25);
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        overflow: hidden;
        border: none;
        cursor: pointer;
        z-index: 1;
      }

      .btn-order::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 50%;
        height: 100%;
        background: linear-gradient(
          to right,
          rgba(255, 255, 255, 0) 0%,
          rgba(255, 255, 255, 0.3) 50%,
          rgba(255, 255, 255, 0) 100%
        );
        transform: skewX(-25deg);
        transition: 0.75s;
        z-index: -1;
      }

      .btn-order:hover::before {
        left: 150%;
        transition: 0.75s;
      }

      .btn-order:hover {
        transform: translateY(-3px);
        box-shadow: 0 15px 30px rgba(212, 175, 55, 0.35);
      }

      .btn-order:active {
        transform: translateY(-1px);
      }

      .btn-order svg {
        transition: transform 0.3s ease;
      }

      .btn-order:hover svg {
        transform: translateX(4px);
      }


      /* Boş Durum (Empty State) Tasarımı */
      .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        background: rgba(255, 255, 255, 0.4);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(212, 175, 55, 0.15);
        border-radius: 24px;
        max-width: 600px;
        margin: 2rem auto;
        box-shadow: 0 15px 45px rgba(44, 37, 32, 0.02);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        animation: fadeInUp 0.8s ease-out;
      }

      .empty-state .icon {
        font-size: 3.5rem;
        animation: pulse 2s infinite ease-in-out;
      }

      .empty-state h3 {
        font-size: 1.8rem;
        font-weight: 700;
        color: var(--text-dark);
      }

      .empty-state p {
        font-size: 1.05rem;
        color: var(--text-muted);
        line-height: 1.6;
        max-width: 450px;
      }

      .btn-follow {
        display: inline-block;
        padding: 0.9rem 2rem;
        background: linear-gradient(135deg, var(--brand-olive) 0%, var(--brand-olive-light) 100%);
        color: white;
        text-decoration: none;
        border-radius: 12px;
        font-weight: 600;
        font-size: 1rem;
        box-shadow: 0 8px 20px rgba(85, 107, 47, 0.2);
        transition: all 0.3s ease;
        margin-top: 0.5rem;
      }

      .btn-follow:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 25px rgba(85, 107, 47, 0.35);
      }

      @keyframes pulse {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.08); }
      }

      /* SIPARIŞ ADIMLARI (Instagram Satış Akışı) */
      .order-steps-section {
        margin: 6rem auto 5rem;
        max-width: 950px;
        text-align: center;
      }

      .steps-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 2rem;
        margin-top: 3rem;
      }

      .step-card {
        background: rgba(255, 255, 255, 0.35);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(212, 175, 55, 0.12);
        border-radius: 20px;
        padding: 2rem 1.5rem;
        position: relative;
        box-shadow: 0 10px 30px rgba(44, 37, 32, 0.02);
      }

      .step-number {
        width: 45px;
        height: 45px;
        background: linear-gradient(135deg, var(--brand-gold) 0%, var(--brand-gold-dark) 100%);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        font-weight: 800;
        margin: 0 auto 1.2rem;
        box-shadow: 0 5px 15px rgba(212, 175, 55, 0.25);
      }

      .step-card h4 {
        font-size: 1.2rem;
        font-weight: 600;
        color: var(--text-dark);
        margin-bottom: 0.6rem;
      }

      .step-card p {
        font-size: 0.95rem;
        color: var(--text-muted);
        line-height: 1.5;
      }

      /* DEĞERLERİMİZ (Neden Biz?) */
      .values-section {
        background: rgba(85, 107, 47, 0.05);
        border: 1px solid rgba(85, 107, 47, 0.1);
        border-radius: 24px;
        padding: 3rem 2rem;
        margin-bottom: 5rem;
        text-align: center;
      }

      .values-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 2.5rem;
        margin-top: 2.5rem;
      }

      .value-item h4 {
        font-size: 1.25rem;
        color: var(--brand-olive);
        margin-bottom: 0.8rem;
        font-weight: 600;
      }

      .value-item p {
        font-size: 0.95rem;
        color: var(--text-muted);
        line-height: 1.6;
      }

      /* SSS (FAQ) Accordion Tasarımı */
      .faq-section {
        max-width: 850px;
        margin: 6rem auto 5rem;
        padding: 0 1.5rem;
        text-align: center;
      }
      
      .faq-list {
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
        margin-top: 2.5rem;
        text-align: left;
      }
      
      .faq-item {
        background: rgba(255, 255, 255, 0.45);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(212, 175, 55, 0.18);
        border-radius: 16px;
        overflow: hidden;
        transition: all 0.3s ease;
      }
      
      .faq-item:hover {
        border-color: rgba(212, 175, 55, 0.4);
        box-shadow: 0 10px 25px rgba(212, 175, 55, 0.08);
      }
      
      .faq-item details {
        padding: 1.2rem 1.5rem;
      }
      
      .faq-item summary {
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--text-dark);
        list-style: none;
        display: flex;
        justify-content: space-between;
        align-items: center;
        cursor: pointer;
        outline: none;
        user-select: none;
      }
      
      .faq-item summary::-webkit-details-marker {
        display: none;
      }
      
      .faq-item summary::after {
        content: '＋';
        font-size: 1.2rem;
        color: var(--brand-gold-dark);
        transition: transform 0.3s ease;
        font-weight: bold;
      }
      
      .faq-item details[open] summary::after {
        content: '－';
        transform: rotate(180deg);
      }
      
      .faq-content {
        margin-top: 1rem;
        color: var(--text-muted);
        font-size: 0.98rem;
        line-height: 1.6;
        padding-top: 0.8rem;
        border-top: 1px dashed rgba(212, 175, 55, 0.15);
        animation: slideDown 0.3s ease-out;
      }

      /* Altbilgi (Footer) */
      footer {
        text-align: center;
        padding: 3rem 0;
        margin-top: auto;
        border-top: 1px solid rgba(212, 175, 55, 0.1);
        color: var(--text-muted);
        font-size: 0.9rem;
      }

      footer .social-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--brand-gold-dark);
        text-decoration: none;
        font-weight: 600;
        font-size: 1.05rem;
        margin-bottom: 1.5rem;
        transition: color 0.3s ease;
      }

      footer .social-link:hover {
        color: var(--brand-olive);
      }

      footer .copyright {
        opacity: 0.75;
      }

      /* Animasyonlar */
      @keyframes rotate {
        100% { transform: rotate(360deg); }
      }

      @keyframes fadeInDown {
        from { opacity: 0; transform: translateY(-30px); }
        to { opacity: 1; transform: translateY(0); }
      }

      @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
      }

      @keyframes slideDown {
        from { opacity: 0; transform: translateY(-10px); }
        to { opacity: 1; transform: translateY(0); }
      }

      .btn-back {
        background: none;
        border: 1px solid rgba(212, 175, 55, 0.25);
        color: var(--text-muted);
        padding: 0.6rem 1.1rem;
        border-radius: 12px;
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        align-self: flex-start;
        margin-bottom: 1.5rem;
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
      }

      .btn-back:hover {
        background: rgba(212, 175, 55, 0.08);
        color: var(--text-dark);
        border-color: var(--brand-gold);
        transform: translateX(-3px);
      }
    </style>
  </head>
  <body>
    <div class="container">
      
      <!-- Üstbilgi (Header) -->
      <header>
        <div class="logo-wrapper">
          <div class="logo-ring"></div>
          <img src="/images/logo.jpg" alt="ES Yaşam Logo" class="logo-img" />
        </div>
        <h1>ES <span>Yaşam</span></h1>
        <p class="slogan">"Daha güzel bir yaşam için"</p>
        <div class="divider"></div>
      </header>

      <!-- Hoş Geldiniz Açıklaması -->
      <section class="intro-card">
        <p>
          Doğadan ilham alan, lüks formüllere sahip temizlik ürünlerimizle tanışın. Stoklarımız her zaman güncel tutulmaktadır. En iyi ve ekonomik ürünleri size en uygun şekilde sunma gayretindeyiz. Ürünlerimizin özelliklerini ve kullanım videolarını aşağıda inceleyebilir, sipariş için doğrudan Instagram DM üzerinden bizimle iletişime geçebilirsiniz!
        </p>
      </section>

      <!-- Ürünler Alanı -->
      <section id="products">
        <h2 class="section-title">Lansman <span>Ürünlerimiz</span></h2>
        
        <div class="products-grid">
          {products.length === 0 ? (
            <div class="empty-state">
              <span class="icon">🌿</span>
              <h3>Yepyeni Ürünlerimiz Pek Yakında!</h3>
              <p>Doğal temizlik ve ferahlık sunan lansman ürünlerimiz hazırlanıyor. Güncel ürünlerimizi ve viral videolarımızı çok yakında burada görebilirsiniz.</p>
              <a href="https://instagram.com/es_yasam" target="_blank" class="btn-follow">Instagram'da Takip Edin</a>
            </div>
          ) : (
            products.map((product, index) => {
              const resolvedImg = resolveProductImage(product.image, product.id);
              
              const campaignPriceNum = parseFloat(product.campaignPrice);
              const salePriceNum = parseFloat(product.salePrice) || 0;
              const hasCampaign = !isNaN(campaignPriceNum) && campaignPriceNum > 0 && campaignPriceNum < salePriceNum;
              
              const currentPrice = hasCampaign ? campaignPriceNum : salePriceNum;
              const originalPrice = hasCampaign ? salePriceNum : null;
              
              return (
                <div 
                  class="product-card" 
                  id={`product-${product.id}`}
                  onClick={() => window.openProductModal(product)}
                >
                  <div class="badge">VİRAL ÜRÜN</div>
                  
                  <div class="product-img-wrapper">
                    <img 
                      src={resolvedImg} 
                      alt={product.name} 
                      class="product-img" 
                      loading={index === 0 ? "eager" : "lazy"} 
                      fetchpriority={index === 0 ? "high" : "auto"}
                    />
                  </div>
                  
                  <div class="product-info">
                    <h3 class="product-name">{product.name}</h3>
                    
                    <div class="price-box">
                      {originalPrice && <span class="price-old">{originalPrice} TL</span>}
                      <span class="price-sale">{currentPrice} TL</span>
                    </div>
                    
                    <div class="product-action-wrapper" 
                      data-id={product.id} 
                      data-name={product.name} 
                      data-price={currentPrice} 
                      data-image={resolvedImg}
                    >
                      <button class="btn-order btn-add-to-cart" 
                        data-id={product.id} 
                        data-name={product.name} 
                        data-price={currentPrice} 
                        data-image={resolvedImg}
                        onClick={(e) => { e.stopPropagation(); window.addToCart(product.id, product.name, currentPrice, resolvedImg); }}
                      >
                        <span>Sepete Ekle</span>
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                          <circle cx="9" cy="21" r="1"></circle>
                          <circle cx="20" cy="21" r="1"></circle>
                          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                        </svg>
                      </button>
                    </div>
                  </div>
                </div>
              );
            })
          )}
        </div>
      </section>

      <!-- SATIN ALMA SÜREÇLERİ -->
      <section class="order-steps-section">
        <h2 class="section-title">Kolay Sipariş <span>Süreci</span></h2>
        <div class="steps-grid">
          <div class="step-card">
            <div class="step-number">1</div>
            <h4>Ürünü Seçin</h4>
            <p>Her zaman güncel tutulan sayfamızdan dilediğiniz ürünü inceleyin.</p>
          </div>
          <div class="step-card">
            <div class="step-number">2</div>
            <h4>Sepete Ekleyin</h4>
            <p>Ürünleri sepetinize ekleyerek siparişinizi dijital olarak oluşturun.</p>
          </div>
          <div class="step-card">
            <div class="step-number">3</div>
            <h4>Kapınıza Gelsin</h4>
            <p>Özenle paketlenen ürünleriniz en kısa sürede adresinize kargolanır.</p>
          </div>
        </div>
      </section>

      <!-- DEĞERLERİMİZ -->
      <section class="values-section">
        <h2 class="section-title">Neden <span>ES Yaşam?</span></h2>
        <div class="values-grid">
          <div class="value-item"><h4>🌿 Doğal ve Güçlü Formül</h4></div>
          <div class="value-item"><h4>✨ Premium Deneyim</h4></div>
          <div class="value-item"><h4>📦 Sızdırmaz Özel Kargo</h4></div>
          <div class="value-item"><h4>💬 Samimi İletişim</h4></div>
        </div>
      </section>

    </div>

    <CartDrawer />

    <footer>
      <a href="https://instagram.com/es_yasam" target="_blank" class="social-link">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle;">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
        </svg>
        Instagram'da Bizi Takip Edin: @es_yasam
      </a>
      <div class="copyright">© 2026 ES Yaşam. Tüm hakları saklıdır.</div>
    </footer>

    <!-- INTERACTIVE SHOPPING ASSISTANT SCRIPT -->
    <script is:inline>
      let currentSlideIndex = 0;

      // ==========================================
      function addToCart(id, name, price, image, quantity = 1) {
        const existing = cart.find(item => item.id === id);
        if (existing) {
          existing.quantity += quantity;
        } else {
          cart.push({ id, name, price: parseFloat(price), image, quantity });
        }
        saveCart();
        showToast(`"${name}" sepete eklendi!`, 'success');
      }

      function updateItemQty(id, change) {
        const item = cart.find(item => item.id === id);
        if (!item) return;

        item.quantity += change;
        if (item.quantity <= 0) {
          cart = cart.filter(item => item.id !== id);
        }
        saveCart();
        renderCart();
      }

      function removeItem(id) {
        const item = cart.find(item => item.id === id);
        if (!item) return;
        cart = cart.filter(item => item.id !== id);
        saveCart();
        renderCart();
        showToast(`"${item.name}" sepetten çıkarıldı.`, 'info');
      }

      // ==========================================
      // CART DRAWER RENDER
      // ==========================================
      function updateStepper(step) {
        const step1 = document.getElementById('step-1-indicator');
        const step2 = document.getElementById('step-2-indicator');
        const progress = document.getElementById('stepper-progress');
        if (!step1 || !step2 || !progress) return;

        if (step === 1) {
          step1.className = 'stepper-step active';
          step2.className = 'stepper-step';
          progress.style.width = '0%';
        } else if (step === 2) {
          step1.className = 'stepper-step completed';
          step2.className = 'stepper-step active';
          progress.style.width = '100%';
        }
      }

      function renderCart() {
        const drawerBody = document.querySelector('#cart-drawer .drawer-body');
        if (!drawerBody) return;

        // Toggle stepper visibility
        const stepper = document.querySelector('#cart-drawer .checkout-stepper');
        if (stepper) {
          stepper.style.display = cart.length === 0 ? 'none' : 'flex';
        }

        if (cart.length === 0) {
          drawerBody.innerHTML = `
            <div class="empty-cart-view">
              <div class="empty-cart-icon-container">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="9" cy="21" r="1"></circle>
                  <circle cx="20" cy="21" r="1"></circle>
                  <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                </svg>
              </div>
              <h4 class="empty-cart-title">Sepetiniz Boş</h4>
              <p class="empty-cart-text">Doğal ve lüks formüllere sahip ürünlerimizden dilediğinizi ekleyip siparişinizi oluşturun!</p>
              <button class="btn-start-shopping">
                <span>Alışverişe Başla</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </button>
            </div>
          `;
          // Close drawer on "Alışverişe Başla" click
          const startShopBtn = drawerBody.querySelector('.btn-start-shopping');
          if (startShopBtn) {
            startShopBtn.addEventListener('click', () => {
              document.getElementById('cart-drawer').classList.remove('show');
              document.body.classList.remove('modal-open');
            });
          }
          return;
        }

        // Update stepper progress
        updateStepper(1);

        let cartItemsHtml = cart.map(item => `
          <div class="cart-item" data-id="${item.id}">
            <img src="${item.image}" alt="${item.name}" class="cart-item-img" />
            <div class="cart-item-info">
              <h4 class="cart-item-name">${item.name}</h4>
              <div class="cart-item-price">${item.price} TL</div>
            </div>
            <div class="cart-item-controls">
              <button class="btn-qty btn-minus" data-id="${item.id}">−</button>
              <span class="qty-val">${item.quantity}</span>
              <button class="btn-qty btn-plus" data-id="${item.id}">＋</button>
            </div>
            <button class="btn-remove" data-id="${item.id}" title="Sepetten Çıkar">
              <svg viewBox="0 0 24 24">
                <path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/>
              </svg>
            </button>
          </div>
        `).join('');

        const total = cart.reduce((sum, item) => sum + (item.price * item.quantity), 0);

        drawerBody.innerHTML = `
          <div class="cart-items-list">
            ${cartItemsHtml}
          </div>
          <div class="cart-summary">
            <div class="summary-row">
              <span class="summary-label">Toplam Tutar:</span>
              <span class="summary-value">${total} TL</span>
            </div>
            <button class="btn-checkout-start">
              <span>Siparişi Tamamla</span>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 18 15 12 9 6"></polyline>
              </svg>
            </button>
          </div>
        `;

        // Bind interactive elements in cart
        drawerBody.querySelectorAll('.btn-minus').forEach(btn => {
          btn.addEventListener('click', () => updateItemQty(btn.getAttribute('data-id'), -1));
        });

        drawerBody.querySelectorAll('.btn-plus').forEach(btn => {
          btn.addEventListener('click', () => updateItemQty(btn.getAttribute('data-id'), 1));
        });

        drawerBody.querySelectorAll('.btn-remove').forEach(btn => {
          btn.addEventListener('click', () => removeItem(btn.getAttribute('data-id')));
        });

        drawerBody.querySelector('.btn-checkout-start').addEventListener('click', renderCheckoutForm);
      }

      // ==========================================
      // CHECKOUT STEP FORM
      // ==========================================
      function renderCheckoutForm() {
        const drawerBody = document.querySelector('#cart-drawer .drawer-body');
        if (!drawerBody) return;

        // Scroll to top of the drawer smoothly
        drawerBody.scrollTop = 0;

        // Update stepper progress
        updateStepper(2);

        const total = cart.reduce((sum, item) => sum + (item.price * item.quantity), 0);

        drawerBody.innerHTML = `
          <button class="btn-back">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="19" y1="12" x2="5" y2="12"></line>
              <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            <span>Sepete Geri Dön</span>
          </button>

          <div class="form-section-title">
            <span>📦 Sipariş ve Kargo Bilgileri</span>
          </div>

          <form id="esyasam-order-form" class="checkout-form">
            <div class="form-group">
              <label for="order-fullname">Ad Soyad</label>
              <input type="text" id="order-fullname" class="form-control" placeholder="Örn: Ahmet Yılmaz" required />
              <span class="error-msg">Lütfen adınızı ve soyadınızı girin.</span>
            </div>

            <div class="form-group">
              <label for="order-phone">Telefon Numarası</label>
              <input type="tel" id="order-phone" class="form-control" placeholder="Örn: 0555 123 4567" required />
              <span class="error-msg">Geçerli bir telefon numarası girin.</span>
            </div>

            <div class="form-group">
              <label for="order-tc">T.C. Kimlik Numarası</label>
              <input type="text" id="order-tc" class="form-control" maxlength="11" placeholder="Kargo ve fatura zorunluluğu" required />
              <span class="error-msg">Lütfen 11 haneli geçerli T.C. Kimlik numaranızı girin.</span>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="order-city">İl</label>
                <input type="text" id="order-city" class="form-control" placeholder="İl" required />
                <span class="error-msg">İl giriniz.</span>
              </div>
              <div class="form-group">
                <label for="order-district">İlçe</label>
                <input type="text" id="order-district" class="form-control" placeholder="İlçe" required />
                <span class="error-msg">İlçe giriniz.</span>
              </div>
            </div>

            <div class="form-group">
              <label for="order-address">Açık Adres</label>
              <textarea id="order-address" class="form-control" rows="3" placeholder="Mahalle, cadde, sokak, bina ve kapı no" required></textarea>
              <span class="error-msg">Lütfen açık adresinizi girin.</span>
            </div>

            <div class="form-group">
              <label for="order-note">Sipariş Notu (Opsiyonel)</label>
              <input type="text" id="order-note" class="form-control" placeholder="Varsa kargo veya ürün notunuz..." />
            </div>

            <div style="margin-top: 1rem; border-top: 1px dashed rgba(212, 175, 55, 0.2); padding-top: 1rem;">
              <div class="summary-row" style="margin-bottom: 1rem;">
                <span class="summary-label" style="font-size: 1rem;">Toplam Tutar:</span>
                <span class="summary-value" style="font-size: 1.3rem;">${total} TL</span>
              </div>
              <button type="submit" class="btn-submit-order">
                <span>Instagram ile Siparişi Tamamla</span>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="9 18 15 12 9 6"></polyline>
                </svg>
              </button>
            </div>
          </form>
        `;

        // Back action
        drawerBody.querySelector('.btn-back').addEventListener('click', renderCart);

        // Numeric constraint for TC
        const tcInput = document.getElementById('order-tc');
        if (tcInput) {
          tcInput.addEventListener('input', (e) => {
            e.target.value = e.target.value.replace(/[^\d]/g, '');
          });
        }

        // Form submit
        const form = document.getElementById('esyasam-order-form');
        if (form) {
          form.addEventListener('submit', handleOrderSubmit);
        }
      }

      function handleOrderSubmit(e) {
        e.preventDefault();

        const fullnameInput = document.getElementById('order-fullname');
        const phoneInput = document.getElementById('order-phone');
        const tcInput = document.getElementById('order-tc');
        const cityInput = document.getElementById('order-city');
        const districtInput = document.getElementById('order-district');
        const addressInput = document.getElementById('order-address');
        const noteInput = document.getElementById('order-note');

        let isValid = true;

        [fullnameInput, phoneInput, cityInput, districtInput, addressInput].forEach(input => {
          if (!input.value.trim()) {
            input.classList.add('invalid');
            isValid = false;
          } else {
            input.classList.remove('invalid');
          }
        });

        const tcVal = tcInput.value.trim();
        if (!tcVal || tcVal.length !== 11 || isNaN(tcVal)) {
          tcInput.classList.add('invalid');
          isValid = false;
        } else {
          tcInput.classList.remove('invalid');
        }

        if (!isValid) {
          showToast('Lütfen formdaki tüm alanları doğru şekilde doldurun.', 'error');
          return;
        }

        const itemsText = cart.map(item => `- ${item.quantity}x ${item.name} (${item.price * item.quantity} TL)`).join('\n');
        const total = cart.reduce((sum, item) => sum + (item.price * item.quantity), 0);

        const orderMessage = `🌟 ES YAŞAM - YENİ SİPARİŞ TALEBİ 🌟
----------------------------------
📦 SİPARİŞ VERİLEN ÜRÜNLER:
${itemsText}

💰 TOPLAM TUTAR: ${total} TL
----------------------------------
👤 ALICI KİMLİK & İLETİŞİM BİLGİLERİ:
Ad Soyad: ${fullnameInput.value.trim()}
Telefon: ${phoneInput.value.trim()}
T.C. Kimlik No: ${tcVal}

📍 TESLİMAT ADRESİ:
${addressInput.value.trim()} - ${districtInput.value.trim()} / ${cityInput.value.trim().toUpperCase()}

📝 MÜŞTERİ NOTU:
${noteInput.value.trim() || 'Yok'}
----------------------------------
Web siteniz üzerinden siparişimi bu detaylarla oluşturmak istiyorum!`;

        // Copy to clipboard
        navigator.clipboard.writeText(orderMessage)
          .then(() => {
            showToast('Sipariş detaylarınız kopyalandı! Instagram DM kutusuna yönlendiriliyorsunuz...', 'success');

            // Reset cart
            cart = [];
            saveCart();

            // Close Drawer
            document.getElementById('cart-drawer').classList.remove('show');
            document.body.classList.remove('modal-open');

            // Open Instagram DM
            setTimeout(() => {
              const baseIntro = `Merhaba, web siteniz üzerinden sipariş bilgilerimi oluşturdum ve kopyaladım. Şimdi buraya yapıştırıp siparişimi başlatıyorum!`;
              window.open(`https://ig.me/m/es_yasam?text=${encodeURIComponent(baseIntro)}`, '_blank');
            }, 1500);
          })
          .catch(err => {
            console.error('Kopyalama hatası:', err);
            showToast('Instagram DM kutusuna aktarılıyorsunuz...', 'success');
            setTimeout(() => {
              window.open('https://ig.me/m/es_yasam', '_blank');
            }, 1500);
          });
      }

      // ==========================================
      // PRODUCT DETAILS SLIDESHOW LOGIC
      // ==========================================
      function showSlide(index) {
        const slides = document.querySelectorAll('.slide-img');
        const dots = document.querySelectorAll('.dot');
        if (slides.length === 0) return;

        if (index >= slides.length) { currentSlideIndex = 0; }
        else if (index < 0) { currentSlideIndex = slides.length - 1; }
        else { currentSlideIndex = index; }

        slides.forEach(slide => slide.classList.remove('active'));
        dots.forEach(dot => dot.classList.remove('active'));

        slides[currentSlideIndex].classList.add('active');
        if (dots[currentSlideIndex]) {
          dots[currentSlideIndex].classList.add('active');
        }
      }

      function getProductImagesList(imageField, productId) {
        if (!imageField) {
          return [`/images/products/${productId}/cover.webp`];
        }
        let images = [];
        if (imageField.includes(',')) {
          images = imageField.split(',').map(img => img.trim());
        } else {
          images = [imageField.trim()];
        }
        return images.map(img => {
          if (!img.includes('/')) {
            return `/images/products/${productId}/${img}`;
          }
          return img;
        });
      }

      function getProductVideosList(videoField) {
        if (!videoField) return [];
        let videos = [];
        if (videoField.includes(',')) {
          videos = videoField.split(',').map(vid => vid.trim()).filter(Boolean);
        } else {
          videos = [videoField.trim()];
        }

        return videos.map(vid => {
          let videoId = "";
          if (vid.includes("youtube.com/shorts/")) {
            videoId = vid.split("youtube.com/shorts/")[1].split("?")[0].split("&")[0];
          } else if (vid.includes("youtu.be/")) {
            videoId = vid.split("youtu.be/")[1].split("?")[0].split("&")[0];
          } else if (vid.includes("v=")) {
            videoId = vid.split("v=")[1].split("&")[0];
          } else if (vid.length === 11) {
            videoId = vid;
          }
          return videoId ? `https://www.youtube.com/embed/${videoId}` : null;
        }).filter(Boolean);
      }

      // ==========================================
      // WINDOW LOAD & INITIAL BINDINGS
      // ==========================================
      window.addEventListener('DOMContentLoaded', () => {
        loadCart();

        // 1. Floating Cart Click
        const floatCartBtn = document.getElementById('floating-cart');
        const cartDrawer = document.getElementById('cart-drawer');
        if (floatCartBtn && cartDrawer) {
          floatCartBtn.addEventListener('click', () => {
            renderCart();
            cartDrawer.classList.add('show');
            document.body.classList.add('modal-open');
          });
        }

        // 2. Drawer Backdrop and Close Click
        const drawerCloseBtn = document.querySelector('#cart-drawer .drawer-close');
        const drawerBackdrop = document.querySelector('#cart-drawer .drawer-backdrop');
        if (cartDrawer) {
          [drawerCloseBtn, drawerBackdrop].forEach(el => {
            if (el) el.addEventListener('click', () => {
              cartDrawer.classList.remove('show');
              document.body.classList.remove('modal-open');
            });
          });
        }

        // 3. Add to Cart Instant Button on Grid Card
        document.querySelectorAll('.btn-add-to-cart').forEach(btn => {
          btn.addEventListener('click', (e) => {
            e.preventDefault(); // Prevent navigating to detail page!
            e.stopPropagation(); // Prevent card trigger
            const id = btn.getAttribute('data-id');
            const name = btn.getAttribute('data-name');
            const price = btn.getAttribute('data-price');
            const image = btn.getAttribute('data-image');
            addToCart(id, name, price, image);
          });
        });
      });
    </script>
  </body>
</html>

