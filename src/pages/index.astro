// ES Yaşam - Premium Tek Sayfalık E-Ticaret Vitrini (Instagram Satış Sayfası Tasarımı)

const databaseUrl = "https://esyasam77-default-rtdb.europe-west1.firebasedatabase.app";
const url = `${databaseUrl}/products.json`;

let products = [];
let dbError = false;

try {
  const response = await fetch(url);
  if (response.ok) {
    const data = await response.json();
    if (data) {
      products = Object.values(data);
    }
  } else {
    dbError = true;
  }
} catch (error) {
  console.error("Firebase veritabanından ürünler çekilirken hata oluştu:", error);
  dbError = true;
}

// Eğer veritabanı boşsa veya hata alındıysa, marka standartlarımıza uygun premium yedek (fallback) verileri gösteriyoruz
if (products.length === 0) {
  products = [
    {
      id: "leke-cikartici",
      name: "Leke Çıkartıcı",
      salePrice: 150,
      features: "Viral temizlik ürünü\nHer türlü zorlu lekeyi saniyeler içinde çıkarır\nKumaş ve yüzey dokusuna zarar vermez\nPratik ve hızlı kullanım",
      image: "/images/products/leke-cikartici/cover.webp",
      video: "https://www.youtube.com/embed/dQw4w9WgXcQ",
      links: "https://instagram.com/es_yasam"
    },
    {
      id: "sari-guc",
      name: "Sarı Güç",
      salePrice: 120,
      features: "Çok amaçlı ultra temizleyici\nYağ, kir ve kireç üzerinde tam etki\nMutfak, banyo ve tüm yüzeylerde güvenli\nFerahlatıcı organik limon kokusu",
      image: "/images/products/sari-guc/cover.webp",
      video: "",
      links: "https://instagram.com/es_yasam"
    },
    {
      id: "mavi-guc",
      name: "Mavi Güç",
      salePrice: 130,
      features: "Ultra yoğun temizlik gücü\nZorlu kirler ve derinlemesine hijyen\nYüzeyleri parlatır ve özel koruma sağlar\nUzun süreli kalıcı lüks ferahlık",
      image: "/images/products/mavi-guc/cover.webp",
      video: "",
      links: "https://instagram.com/es_yasam"
    }
  ];
}

/**
 * YouTube linklerini (Shorts dahil) otomatik olarak embed koduna çeviren akıllı yardımcı fonksiyon.
 */
function getYoutubeEmbedUrl(url) {
  if (!url) return null;
  let videoId = "";
  
  if (url.includes("youtube.com/shorts/")) {
    videoId = url.split("youtube.com/shorts/")[1].split("?")[0].split("&")[0];
  } else if (url.includes("youtu.be/")) {
    videoId = url.split("youtu.be/")[1].split("?")[0].split("&")[0];
  } else if (url.includes("v=")) {
    videoId = url.split("v=")[1].split("&")[0];
  } else if (url.length === 11) {
    videoId = url;
  }
  
  return videoId ? `https://www.youtube.com/embed/${videoId}` : null;
}

/**
 * E-tablodaki resim isimlerini veya boş yolları akıllı klasör yapımızla eşleyen yardımcı fonksiyon.
 */
function resolveProductImage(image, id) {
  if (!image) {
    return `/images/products/${id}/cover.webp`;
  }
  if (!image.includes("/")) {
    return `/images/products/${id}/${image}`;
  }
  return image;
}
