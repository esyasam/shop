  /* Bounce Animation for badge bump */
  @keyframes bounce {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.3); }
  }

  /* Kargo Bedava Progress Bar */
  .kargo-bedava-container {
    background: rgba(85, 107, 47, 0.05);
    border: 1px solid rgba(85, 107, 47, 0.1);
    padding: 0.85rem 1.1rem;
    border-radius: 14px;
    margin-bottom: 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    animation: fadeIn 0.3s ease-out;
  }
  .kargo-text {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--brand-olive);
    text-align: center;
  }
  .kargo-text b {
    color: var(--brand-gold-dark);
  }
  .kargo-bar-bg {
    background: rgba(212, 175, 55, 0.12);
    height: 6px;
    border-radius: 10px;
    overflow: hidden;
    position: relative;
  }
  .kargo-bar-fill {
    background: linear-gradient(to right, var(--brand-gold) 0%, var(--brand-olive) 100%);
    height: 100%;
    border-radius: 10px;
    width: 0%;
    transition: width 0.4s ease-out;
  }

  /* Clear Cart Header Button */
  .btn-clear-cart {
    background: none;
    border: none;
    color: #e74c3c;
    cursor: pointer;
    font-size: 1.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    transition: background 0.3s ease;
    margin-right: 48px; /* Room for close button */
    padding: 0;
  }
  .btn-clear-cart:hover {
    background: rgba(231, 76, 60, 0.08);
  }
  .btn-clear-cart svg {
    display: block;
    stroke: currentColor;
  }
</style>

<script is:inline>
  let cart = [];

  // ==========================================
  // TOAST NOTIFICATIONS SYSTEM
  // ==========================================
  function showToast(message, type = 'success', duration = 4000) {
    const container = document.getElementById('toast-container');
    if (!container) return;

    const toast = document.createElement('div');
    toast.className = `toast ${type}`;

    const icon = type === 'success' ? '✨' : (type === 'error' ? '❌' : 'ℹ️');
    toast.innerHTML = `
      <span class="toast-icon">${icon}</span>
      <span>${message}</span>
    `;

    container.appendChild(toast);

    // Entry animation
    setTimeout(() => toast.classList.add('show'), 50);

    // Auto remove
    setTimeout(() => {
      toast.classList.remove('show');
      setTimeout(() => toast.remove(), 400);
    }, duration);
  }

  // ==========================================
  // SHOPPING CART CORE LOGIC
  // ==========================================
  function loadCart() {
    const saved = localStorage.getItem('esyasam_cart');
    if (saved) {
      try {
        cart = JSON.parse(saved);
      } catch (e) {
        cart = [];
      }
    }
    updateCartBadge();
    // Dispatch custom event on load to initialize any page widgets
    window.dispatchEvent(new CustomEvent('cart-updated', { detail: { cart } }));
  }

  function saveCart() {
    localStorage.setItem('esyasam_cart', JSON.stringify(cart));
    updateCartBadge();
    // Dispatch custom event to notify other scripts on the page
    window.dispatchEvent(new CustomEvent('cart-updated', { detail: { cart } }));
  }

  // Sadece sepet çekmecesini değil, varsa header'daki sayaçları da günceller.
  function updateCartBadge() {
    const totalCount = cart.reduce((sum, item) => sum + item.quantity, 0);

    // Floating cart badge
    const countBadge = document.getElementById('cart-count');
    if (countBadge) {
      countBadge.textContent = totalCount;
      countBadge.classList.remove('bump');
      void countBadge.offsetWidth; // Force reflow
      countBadge.classList.add('bump');
    }

    // Header/Navbar cart badge (if present)
    const navCountBadge = document.getElementById('nav-cart-count');
    if (navCountBadge) {
      navCountBadge.textContent = totalCount;
    }
  }

  function addToCart(id, name, price, image, quantity = 1) {
    const existing = cart.find(item => String(item.id) === String(id));
    if (existing) {
      existing.quantity += quantity;
    } else {
      cart.push({ id: String(id), name, price: parseFloat(price), image, quantity });
    }
    saveCart();
    showToast(`"${name}" sepete eklendi!`, 'success');
  }

  function updateItemQty(id, change) {
    const item = cart.find(item => String(item.id) === String(id));
    if (!item) return;

    item.quantity += change;
    if (item.quantity <= 0) {
      cart = cart.filter(item => String(item.id) !== String(id));
    }
    saveCart();
    renderCart();
  }

  function removeItem(id) {
    const item = cart.find(item => String(item.id) === String(id));
    if (!item) return;
    cart = cart.filter(item => String(item.id) !== String(id));
    saveCart();
    renderCart();
    showToast(`"${item.name}" sepetten çıkarıldı.`, 'info');
  }

  // ==========================================
  // CART DRAWER RENDER
  // ==========================================
  function updateStepper(step) {
    const step1 = document.getElementById('step-1-indicator');
    const step2 = document.getElementById('step-2-indicator');
    const progress = document.getElementById('stepper-progress');
    if (!step1 || !step2 || !progress) return;

    if (step === 1) {
      step1.className = 'stepper-step active';
      step2.className = 'stepper-step';
      progress.style.width = '0%';
    } else if (step === 2) {
      step1.className = 'stepper-step completed';
      step2.className = 'stepper-step active';
      progress.style.width = '100%';
    }
  }

  function renderCart() {
    const drawerBody = document.querySelector('#cart-drawer .drawer-body');
    if (!drawerBody) return;

    // Toggle stepper visibility
    const stepper = document.querySelector('#cart-drawer .checkout-stepper');
    if (stepper) {
      stepper.style.display = cart.length === 0 ? 'none' : 'flex';
    }

    const clearBtn = document.getElementById('header-clear-cart');

    if (cart.length === 0) {
      if (clearBtn) clearBtn.style.display = 'none';
      drawerBody.innerHTML = `
        <div class="empty-cart-view">
          <div class="empty-cart-icon-container">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="9" cy="21" r="1"></circle>
              <circle cx="20" cy="21" r="1"></circle>
              <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
            </svg>
          </div>
          <h4 class="empty-cart-title">Sepetiniz Boş</h4>
          <p class="empty-cart-text">Doğal ve lüks formüllere sahip ürünlerimizden dilediğinizi ekleyip siparişinizi oluşturun!</p>
          <button class="btn-start-shopping">
            <span>Alışverişe Başla</span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </button>
        </div>
      `;
      // Close drawer on "Alışverişe Başla" click
      const startShopBtn = drawerBody.querySelector('.btn-start-shopping');
      if (startShopBtn) {
        startShopBtn.addEventListener('click', () => {
          document.getElementById('cart-drawer').classList.remove('show');
          document.body.classList.remove('modal-open');
        });
      }
      return;
    }

    if (clearBtn) clearBtn.style.display = 'flex';

    // Update stepper progress
    updateStepper(1);

    let cartItemsHtml = cart.map(item => `
      <div class="cart-item" data-id="${item.id}">
        <img src="${item.image}" alt="${item.name}" class="cart-item-img" />
        <div class="cart-item-info">
          <h4 class="cart-item-name">${item.name}</h4>
          <div class="cart-item-price">${item.price} TL</div>
        </div>
        <div class="cart-item-controls">
          <button class="btn-qty btn-minus" data-id="${item.id}" aria-label="Azalt">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
          </button>
          <span class="qty-val">${item.quantity}</span>
          <button class="btn-qty btn-plus" data-id="${item.id}" aria-label="Artır">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="12" y1="5" x2="12" y2="19"></line>
              <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
          </button>
        </div>
        <button class="btn-remove" data-id="${item.id}" title="Sepetten Çıkar">
          <svg viewBox="0 0 24 24">
            <path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/>
          </svg>
        </button>
      </div>
    `).join('');

    const total = cart.reduce((sum, item) => sum + (item.price * item.quantity), 0);
    const kargoLimit = 1500;
    let kargoHtml = '';
    
    if (total >= kargoLimit) {
      kargoHtml = `
        <div class="kargo-bedava-container">
          <div class="kargo-text">🚚 Tebrikler, <b>kargo ücretsiz!</b> Limit aşıldı.</div>
          <div class="kargo-bar-bg">
            <div class="kargo-bar-fill" style="width: 100%;"></div>
          </div>
        </div>
      `;
    } else {
      const remaining = kargoLimit - total;
      const percent = (total / kargoLimit) * 100;
      kargoHtml = `
        <div class="kargo-bedava-container">
          <div class="kargo-text">ℹ️ Sepetinize <b>${remaining.toFixed(2)} TL</b> değerinde ürün ekleyin, kargo bedava olsun!</div>
          <div class="kargo-bar-bg">
            <div class="kargo-bar-fill" style="width: ${percent}%;"></div>
          </div>
        </div>
      `;
    }

    drawerBody.innerHTML = `
      ${kargoHtml}
      <div class="cart-items-list">
        ${cartItemsHtml}
      </div>
      <div class="cart-summary">
        <div class="summary-row">
          <span class="summary-label">Toplam Tutar:</span>
          <span class="summary-value">${total.toFixed(2)} TL</span>
        </div>
        <button class="btn-checkout-start">
          <span>Siparişi Tamamla</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>
      </div>
    `;

    // Bind interactive elements in cart
    drawerBody.querySelectorAll('.btn-minus').forEach(btn => {
      btn.addEventListener('click', () => updateItemQty(btn.getAttribute('data-id'), -1));
    });

    drawerBody.querySelectorAll('.btn-plus').forEach(btn => {
      btn.addEventListener('click', () => updateItemQty(btn.getAttribute('data-id'), 1));
    });

    drawerBody.querySelectorAll('.btn-remove').forEach(btn => {
      btn.addEventListener('click', () => removeItem(btn.getAttribute('data-id')));
    });

    drawerBody.querySelector('.btn-checkout-start').addEventListener('click', renderCheckoutForm);
  }

  // ==========================================
  // CUSTOMER INFO CACHING & UTILS
  // ==========================================
  function loadCustomerInfo() {
    const saved = localStorage.getItem('esyasam_customer_info');
    if (saved) {
      try {
        return JSON.parse(saved);
      } catch (e) {
        return null;
      }
    }
    return null;
  }

  function clearCart() {
    if (confirm("Sepetinizi boşaltmak istediğinize emin misiniz?")) {
      cart = [];
      saveCart();
      renderCart();
      showToast("Sepetiniz boşaltıldı.", "info");
    }
  }
  window.clearCart = clearCart;

  // ==========================================
  // CHECKOUT STEP FORM
  // ==========================================
  function renderCheckoutForm() {
    const drawerBody = document.querySelector('#cart-drawer .drawer-body');
    if (!drawerBody) return;

    drawerBody.scrollTop = 0;
    updateStepper(2);

    const clearBtn = document.getElementById('header-clear-cart');
    if (clearBtn) clearBtn.style.display = 'none';

    const total = cart.reduce((sum, item) => sum + (item.price * item.quantity), 0);

    const customerInfo = loadCustomerInfo();
    const fullname = customerInfo ? customerInfo.fullname : '';
    const phone = customerInfo ? customerInfo.phone : '';
    const tc = customerInfo ? customerInfo.tc : '';
    const city = customerInfo ? customerInfo.city : '';
    const district = customerInfo ? customerInfo.district : '';
    const address = customerInfo ? customerInfo.address : '';
    const note = customerInfo ? customerInfo.note : '';
    const sameAddress = customerInfo ? customerInfo.sameAddress !== false : true;
    const deliveryAddress = customerInfo ? customerInfo.deliveryAddress : '';
    const paymentMethod = customerInfo ? customerInfo.paymentMethod : 'Kredi Kartı';

    drawerBody.innerHTML = `
      <button class="btn-back">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        <span>Sepete Geri Dön</span>
      </button>

      <div class="form-section-title">
        <span>📦 Sipariş ve Kargo Bilgileri</span>
      </div>

      <form id="esyasam-order-form" class="checkout-form">
        <div class="form-group">
          <label for="order-fullname">Ad Soyad</label>
          <input type="text" id="order-fullname" class="form-control" placeholder="Örn: Ahmet Yılmaz" value="${fullname}" required />
          <span class="error-msg">Lütfen adınızı ve soyadınızı girin.</span>
        </div>

        <div class="form-group">
          <label for="order-phone">Telefon Numarası</label>
          <input type="tel" id="order-phone" class="form-control" placeholder="Örn: 0555 123 4567" value="${phone}" required />
          <span class="error-msg">Geçerli bir telefon numarası girin.</span>
        </div>

        <div class="form-group">
          <label for="order-tc">T.C. Kimlik Numarası</label>
          <input type="text" id="order-tc" class="form-control" maxlength="11" placeholder="Kargo ve fatura zorunluluğu" value="${tc}" required />
          <span class="error-msg">Lütfen 11 haneli geçerli T.C. Kimlik numaranızı girin.</span>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="order-city">İl</label>
            <input type="text" id="order-city" class="form-control" placeholder="İl" value="${city}" required />
            <span class="error-msg">İl giriniz.</span>
          </div>
          <div class="form-group">
            <label for="order-district">İlçe</label>
            <input type="text" id="order-district" class="form-control" placeholder="İlçe" value="${district}" required />
            <span class="error-msg">İlçe giriniz.</span>
          </div>
        </div>

        <div class="form-group">
          <label for="order-address">Fatura Adresi</label>
          <textarea id="order-address" class="form-control" rows="3" placeholder="Mahalle, cadde, sokak, bina ve kapı no" required>${address}</textarea>
          <span class="error-msg">Lütfen fatura adresinizi girin.</span>
        </div>

        <div class="form-group-checkbox" style="display: flex; align-items: center; gap: 8px; margin: 0.5rem 0;">
          <input type="checkbox" id="same-address-check" ${sameAddress ? 'checked' : ''} style="width: 18px; height: 18px; cursor: pointer;" />
          <label for="same-address-check" style="font-size: 0.8rem; font-weight: 600; color: var(--text-muted); text-transform: none; cursor: pointer; user-select: none;">Teslimat adresi fatura adresi ile aynı</label>
        </div>

        <div id="delivery-address-group" class="form-group" style="${sameAddress ? 'display: none;' : ''}">
          <label for="order-delivery-address">Teslimat Adresi</label>
          <textarea id="order-delivery-address" class="form-control" rows="2" placeholder="Siparişin gönderileceği teslimat adresi">${deliveryAddress}</textarea>
          <span class="error-msg">Lütfen teslimat adresinizi girin.</span>
        </div>

        <div class="form-group">
          <label for="order-payment">Ödeme Yöntemi</label>
          <select id="order-payment" class="form-control" style="cursor: pointer; appearance: auto;">
            <option value="Kredi Kartı" ${paymentMethod === 'Kredi Kartı' ? 'selected' : ''}>Online Kredi Kartı</option>
            <option value="Havale/EFT" ${paymentMethod === 'Havale/EFT' ? 'selected' : ''}>Bankaya Havale / EFT</option>
          </select>
        </div>

        <div class="form-group">
          <label for="order-note">Sipariş Notu (Opsiyonel)</label>
          <input type="text" id="order-note" class="form-control" placeholder="Varsa kargo veya ürün notunuz..." value="${note}" />
        </div>

        <div style="margin-top: 1rem; border-top: 1px dashed rgba(212, 175, 55, 0.2); padding-top: 1rem;">
          <div class="summary-row" style="margin-bottom: 1rem;">
            <span class="summary-label" style="font-size: 1rem;">Toplam Tutar:</span>
            <span class="summary-value" style="font-size: 1.3rem;">${total.toFixed(2)} TL</span>
          </div>
          <button type="submit" class="btn-submit-order">
            <span>Instagram ile Siparişi Tamamla</span>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </button>
        </div>
      </form>
    `;

    // Back action
    drawerBody.querySelector('.btn-back').addEventListener('click', renderCart);

    // Toggle delivery address display on sameAddressCheck change
    const sameAddressCheck = document.getElementById('same-address-check');
    const deliveryGroup = document.getElementById('delivery-address-group');
    const deliveryAddressInput = document.getElementById('order-delivery-address');
    
    if (sameAddressCheck && deliveryGroup) {
      sameAddressCheck.addEventListener('change', (e) => {
        if (e.target.checked) {
          deliveryGroup.style.display = 'none';
          if (deliveryAddressInput) deliveryAddressInput.removeAttribute('required');
        } else {
          deliveryGroup.style.display = 'flex';
          if (deliveryAddressInput) deliveryAddressInput.setAttribute('required', 'required');
        }
      });
    }

    if (deliveryAddressInput && !sameAddress) {
      deliveryAddressInput.setAttribute('required', 'required');
    }

    // Numeric constraint for TC
    const tcInput = document.getElementById('order-tc');
    if (tcInput) {
      tcInput.addEventListener('input', (e) => {
        e.target.value = e.target.value.replace(/[^\d]/g, '');
      });
    }

    // Form submit
    const form = document.getElementById('esyasam-order-form');
    if (form) {
      form.addEventListener('submit', handleOrderSubmit);
    }
  }

  function handleOrderSubmit(e) {
    e.preventDefault();

    const fullnameInput = document.getElementById('order-fullname');
    const phoneInput = document.getElementById('order-phone');
    const tcInput = document.getElementById('order-tc');
    const cityInput = document.getElementById('order-city');
    const districtInput = document.getElementById('order-district');
    const addressInput = document.getElementById('order-address');
    const noteInput = document.getElementById('order-note');
    const sameAddressCheck = document.getElementById('same-address-check');
    const deliveryAddressInput = document.getElementById('order-delivery-address');
    const paymentSelect = document.getElementById('order-payment');

    let isValid = true;

    [fullnameInput, phoneInput, cityInput, districtInput, addressInput].forEach(input => {
      if (!input.value.trim()) {
        input.classList.add('invalid');
        isValid = false;
      } else {
        input.classList.remove('invalid');
      }
    });

    const tcVal = tcInput.value.trim();
    if (!tcVal || tcVal.length !== 11 || isNaN(tcVal)) {
      tcInput.classList.add('invalid');
      isValid = false;
    } else {
      tcInput.classList.remove('invalid');
    }

    const isSameAddress = sameAddressCheck ? sameAddressCheck.checked : true;
    let deliveryAddressVal = addressInput.value.trim();
    if (!isSameAddress) {
      if (deliveryAddressInput && !deliveryAddressInput.value.trim()) {
        deliveryAddressInput.classList.add('invalid');
        isValid = false;
      } else if (deliveryAddressInput) {
        deliveryAddressInput.classList.remove('invalid');
        deliveryAddressVal = deliveryAddressInput.value.trim();
      }
    }

    if (!isValid) {
      showToast('Lütfen formdaki tüm alanları doğru şekilde doldurun.', 'error');
      return;
    }

    const paymentMethodVal = paymentSelect ? paymentSelect.value : 'Kredi Kartı';

    // Save customer info in localStorage for auto-filling
    const customerInfo = {
      fullname: fullnameInput.value.trim(),
      phone: phoneInput.value.trim(),
      tc: tcVal,
      city: cityInput.value.trim(),
      district: districtInput.value.trim(),
      address: addressInput.value.trim(),
      note: noteInput ? noteInput.value.trim() : '',
      sameAddress: isSameAddress,
      deliveryAddress: isSameAddress ? '' : deliveryAddressVal,
      paymentMethod: paymentMethodVal
    };
    localStorage.setItem('esyasam_customer_info', JSON.stringify(customerInfo));

    const itemsText = cart.map(item => `- ${item.quantity}x ${item.name} (${(item.price * item.quantity).toFixed(2)} TL)`).join('\n');
    const total = cart.reduce((sum, item) => sum + (item.price * item.quantity), 0);

    const orderMessage = `🌟 ES YAŞAM - YENİ SİPARİŞ TALEBİ 🌟
----------------------------------
📦 SİPARİŞ VERİLEN ÜRÜNLER:
${itemsText}

💰 TOPLAM TUTAR: ${total.toFixed(2)} TL
💳 ÖDEME YÖNTEMİ: ${paymentMethodVal}
----------------------------------
👤 ALICI KİMLİK & İLETİŞİM BİLGİLERİ:
Ad Soyad: ${fullnameInput.value.trim()}
Telefon: ${phoneInput.value.trim()}
T.C. Kimlik No: ${tcVal}

📍 FATURA ADRESİ:
${addressInput.value.trim()} - ${districtInput.value.trim()} / ${cityInput.value.trim().toUpperCase()}

📍 TESLİMAT ADRESİ:
${isSameAddress ? 'Fatura Adresi ile Aynı' : `${deliveryAddressVal} - ${districtInput.value.trim()} / ${cityInput.value.trim().toUpperCase()}`}

📝 MÜŞTERİ NOTU:
${noteInput ? (noteInput.value.trim() || 'Yok') : 'Yok'}
----------------------------------
Web siteniz üzerinden siparişimi bu detaylarla oluşturmak istiyorum!`;

    // Copy to clipboard
    navigator.clipboard.writeText(orderMessage)
      .then(() => {
        showToast('Sipariş detaylarınız kopyalandı! Instagram DM kutusuna yönlendiriliyorsunuz...', 'success');

        // Reset cart
        cart = [];
        saveCart();

        // Close Drawer
        document.getElementById('cart-drawer').classList.remove('show');
        document.body.classList.remove('modal-open');

        // Open Instagram DM
        setTimeout(() => {
          const baseIntro = `Merhaba, web siteniz üzerinden sipariş bilgilerimi oluşturdum ve kopyaladım. Şimdi buraya yapıştırıp siparişimi başlatıyorum!`;
          window.open(`https://ig.me/m/es_yasam?text=${encodeURIComponent(baseIntro)}`, '_blank');
        }, 1500);
      })
      .catch(err => {
        console.error('Kopyalama hatası:', err);
        showToast('Instagram DM kutusuna aktarılıyorsunuz...', 'success');
        setTimeout(() => {
          window.open('https://ig.me/m/es_yasam', '_blank');
        }, 1500);
      });
  }

  // ==========================================
  // GLOBALLY ACCESSIBLE API BINDINGS
  // ==========================================
  // Expose cart getter and setter dynamically so other scripts can interact with it reactively
  Object.defineProperty(window, 'cart', {
    get: () => cart,
    set: (val) => {
      cart = val;
      saveCart();
      renderCart();
    },
    configurable: true
  });

  window.addToCart = addToCart;
  window.updateItemQty = updateItemQty;
  window.removeItem = removeItem;
  window.showToast = showToast;
  window.openCartDrawer = function() {
    renderCart();
    const cartDrawer = document.getElementById('cart-drawer');
    if (cartDrawer) {
      cartDrawer.classList.add('show');
      document.body.classList.add('modal-open');
    }
  };
  window.openCheckoutDrawer = function() {
    renderCheckoutForm();
    const cartDrawer = document.getElementById('cart-drawer');
    if (cartDrawer) {
      cartDrawer.classList.add('show');
      document.body.classList.add('modal-open');
    }
  };

  // ==========================================
  // WINDOW LOAD & EVENT BINDINGS
  // ==========================================
  window.addEventListener('DOMContentLoaded', () => {
    loadCart();

    // 1. Floating Cart Click
    const floatCartBtn = document.getElementById('floating-cart');
    const cartDrawer = document.getElementById('cart-drawer');
    if (floatCartBtn && cartDrawer) {
      floatCartBtn.addEventListener('click', () => {
        window.openCartDrawer();
      });
    }

    // 2. Drawer Backdrop and Close Click
    const drawerCloseBtn = document.querySelector('#cart-drawer .drawer-close');
    const drawerBackdrop = document.querySelector('#cart-drawer .drawer-backdrop');
    if (cartDrawer) {
      [drawerCloseBtn, drawerBackdrop].forEach(el => {
        if (el) el.addEventListener('click', () => {
          cartDrawer.classList.remove('show');
          document.body.classList.remove('modal-open');
        });
      });
    }

    // 3. Clear Cart Click
    const clearCartBtn = document.getElementById('header-clear-cart');
    if (clearCartBtn) {
      clearCartBtn.addEventListener('click', () => {
        window.clearCart();
      });
    }
  });
</script>
